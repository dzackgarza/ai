{
  "$schema": "https://raw.githubusercontent.com/kenryu42/claude-code-safety-net/main/assets/cc-safety-net.schema.json",
  "version": 1,
  "rules": [
    {
      "name": "block-git-checkout-ref-path",
      "command": "git",
      "subcommand": "checkout",
      "block_args": [
        "--"
      ],
      "reason": "To revert state (files or branch point), maintain an audit trail: commit work, diff to identify the rollback point, and apply the reverse diff. NEVER use git stash - review git guidelines skill immediately."
    },
    {
      "name": "block-git-checkout-file-restore",
      "command": "git",
      "subcommand": "checkout",
      "block_args": [
        "--"
      ],
      "reason": "To revert state (files or branch point), maintain an audit trail: commit work, diff to identify the rollback point, and apply the reverse diff. NEVER use git stash - review git guidelines skill immediately."
    },
    {
      "name": "block-rm",
      "command": "rm",
      "block_args": [
        "-r",
        "-rf",
        "-fr",
        "-f"
      ],
      "reason": "Use recoverable deletion (`trash` or `gio trash`) instead of `rm`."
    },
    {
      "name": "block-find-delete",
      "command": "find",
      "block_args": [
        "-delete"
      ],
      "reason": "Destructive deletion is blocked. Use 'trash' instead of 'find ... -delete'."
    },
    {
      "name": "block-trash-empty",
      "command": "trash-empty",
      "block_args": [
        "trash-empty"
      ],
      "reason": "Emptying the trash is not allowed by security policy. No agent may permanently delete any files from the system. All permanent deletions must be user choices. If permanent deletion is needed, the agent must explicitly ask the user to perform it."
    },
    {
      "name": "block-sed",
      "command": "sed",
      "block_args": [
        "sed"
      ],
      "reason": "Direct file manipulation with sed is banned. Agents must use proper editing tools (like Edit or Write) so that changes produce clear diffs for user review in chat."
    },
    {
      "name": "block-git-push",
      "command": "git",
      "subcommand": "push",
      "block_args": [
        "push",
        "--force",
        "-f",
        "--force-with-lease"
      ],
      "reason": "Pushing is not part of the PR-based workflow. Review the git guidelines skill for the proper workflow."
    },
    {
      "name": "block-git-switch",
      "command": "git",
      "subcommand": "switch",
      "block_args": [
        "switch",
        "-c",
        "-C"
      ],
      "reason": "To revert state (files or branch point), maintain an audit trail: commit work, diff to identify the rollback point, and apply the reverse diff. New feature work should be PR-driven via the GitHub CLI."
    },
    {
      "name": "block-git-branch",
      "command": "git",
      "subcommand": "branch",
      "block_args": [
        "branch",
        "-m",
        "-M",
        "-d",
        "-D",
        "-c",
        "-C"
      ],
      "reason": "Branch management should be PR-driven. Create branches for feature work via \"gh pr create\"."
    },
    {
      "name": "block-git-add-all",
      "command": "git",
      "subcommand": "add",
      "block_args": [
        ".",
        "-A",
        "--all"
      ],
      "reason": "Blanket staging risks committing secrets. Use targeted \"git add\", or \"git add -u\" for snapshots/checkpoints of tracked files."
    },
    {
      "name": "block-git-add-interactive",
      "command": "git",
      "subcommand": "add",
      "block_args": [
        "-i",
        "--interactive"
      ],
      "reason": "Interactive staging is blocked. Review changes with 'git status' and 'git diff' before adding."
    },
    {
      "name": "block-git-stash",
      "command": "git",
      "subcommand": "stash",
      "block_args": [
        "stash",
        "save"
      ],
      "reason": "Stashing is discouraged. Use \"checkpoint\" commits to save work. To clear the deck, use the audit-trail rollback: commit the mess, then apply a reverse diff of the mess."
    },
    {
      "name": "block-git-stash-pop",
      "command": "git",
      "subcommand": "stash",
      "block_args": [
        "pop",
        "apply"
      ],
      "reason": "Stashing is banned as it leads to surprising hidden states that can get lost. Review the git guidelines skill immediately."
    },
    {
      "name": "block-git-revert",
      "command": "git",
      "subcommand": "revert",
      "block_args": [
        "revert"
      ],
      "reason": "Maintaining an audit trail is required. To roll back, commit your current work, diff the commits to identify the rollback point, and apply the reverse diff to a new commit."
    },
    {
      "name": "block-git-reset",
      "command": "git",
      "subcommand": "reset",
      "block_args": [
        "reset",
        "--hard",
        "--mixed",
        "--soft"
      ],
      "reason": "Maintaining an audit trail is required. To roll back, commit your current work, diff the commits to identify the rollback point, and apply the reverse diff to a new commit."
    },
    {
      "name": "block-git-clean",
      "command": "git",
      "subcommand": "clean",
      "block_args": [
        "clean",
        "-f",
        "-fd",
        "-fx",
        "-fdx"
      ],
      "reason": "Maintaining an audit trail is required. To roll back, commit your current work, diff the commits to identify the rollback point, and apply the reverse diff to a new commit."
    },
    {
      "name": "block-git-restore",
      "command": "git",
      "subcommand": "restore",
      "block_args": [
        "restore"
      ],
      "reason": "Maintaining an audit trail is required. To roll back, commit your current work, diff the commits to identify the rollback point, and apply the reverse diff to a new commit."
    },
    {
      "name": "block-git-rebase",
      "command": "git",
      "subcommand": "rebase",
      "block_args": [
        "rebase"
      ],
      "reason": "History rewrites can disrupt collaborators. Use the GitHub PR interface to handle merges and rebases."
    },
    {
      "name": "block-git-merge",
      "command": "git",
      "subcommand": "merge",
      "block_args": [
        "merge"
      ],
      "reason": "History rewrites can disrupt collaborators. Use the GitHub PR interface to handle merges and rebases."
    },
    {
      "name": "block-git-commit-no-verify",
      "command": "git",
      "subcommand": "commit",
      "block_args": [
        "--no-verify"
      ],
      "reason": "Skipping hooks is blocked."
    },
    {
      "name": "block-git-commit-no-gpg-sign",
      "command": "git",
      "subcommand": "commit",
      "block_args": [
        "--no-gpg-sign"
      ],
      "reason": "Bypassing signing is blocked."
    },
    {
      "name": "block-bun-test",
      "command": "bun",
      "subcommand": "test",
      "block_args": [
        "test"
      ],
      "reason": "All tests must be routed through a justfile recipe which properly initializes the testing env."
    },
    {
      "name": "block-npm-test",
      "command": "npm",
      "subcommand": "test",
      "block_args": [
        "test"
      ],
      "reason": "All tests must be routed through a justfile recipe which properly initializes the testing env."
    },
    {
      "name": "block-pytest",
      "command": "pytest",
      "block_args": [
        "test"
      ],
      "reason": "All tests must be routed through a justfile recipe which properly initializes the testing env."
    },
    {
      "name": "block-vitest",
      "command": "vitest",
      "block_args": [
        "test"
      ],
      "reason": "All tests must be routed through a justfile recipe which properly initializes the testing env."
    },
    {
      "name": "block-python-pytest",
      "command": "python",
      "block_args": [
        "-m",
        "pytest"
      ],
      "reason": "All tests must be routed through a justfile recipe which properly initializes the testing env."
    },
    {
      "name": "block-direnv-tests",
      "command": "direnv",
      "subcommand": "exec",
      "block_args": [
        "bun",
        "npm",
        "pytest",
        "vitest"
      ],
      "reason": "direnv exec bypasses justfile env initialization. Use 'just test' instead."
    },
    {
      "name": "block-uv-pytest",
      "command": "uv",
      "subcommand": "run",
      "block_args": [
        "pytest"
      ],
      "reason": "All tests must be routed through a justfile recipe which properly initializes the testing env."
    },
    {
      "name": "block-uv-vitest",
      "command": "uv",
      "subcommand": "run",
      "block_args": [
        "vitest"
      ],
      "reason": "All tests must be routed through a justfile recipe which properly initializes the testing env."
    },
    {
      "name": "block-just-typecheck",
      "command": "just",
      "subcommand": "typecheck",
      "block_args": [
        "typecheck"
      ],
      "reason": "Use \"just test\" which includes typecheck as a dependency. Do not bypass the full test suite."
    },
    {
      "name": "block-just-check",
      "command": "just",
      "subcommand": "check",
      "block_args": [
        "check"
      ],
      "reason": "Use \"just test\" which includes check as a dependency. Do not bypass the full test suite."
    },
    {
      "name": "block-npm-install-global",
      "command": "npm",
      "subcommand": "install",
      "block_args": [
        "-g",
        "--global"
      ],
      "reason": "Global package installation is banned. All CLIs should be run using npx/uvx/bunx. If needed as a dependency, it must be recorded in package.json and installed via justfile recipe. Agents may not mutate global packages."
    },
    {
      "name": "block-pip-install-global",
      "command": "pip",
      "subcommand": "install",
      "block_args": [
        "--user"
      ],
      "reason": "Global package installation is banned. All CLIs should be run using uvx/npx. If needed as a dependency, it must be recorded in pyproject.toml and installed via justfile recipe. Agents may not mutate global packages."
    },
    {
      "name": "block-yarn-global",
      "command": "yarn",
      "subcommand": "global",
      "block_args": [
        "add"
      ],
      "reason": "Global package installation is banned. All CLIs should be run using npx/uvx/bunx. If needed as a dependency, it must be recorded in package.json and installed via justfile recipe. Agents may not mutate global packages."
    },
    {
      "name": "block-npm-uninstall-global",
      "command": "npm",
      "subcommand": "uninstall",
      "block_args": [
        "-g",
        "--global"
      ],
      "reason": "Global package removal is banned. Agents may not mutate global packages. If a global package is problematic, alert the user to manually uninstall it."
    },
    {
      "name": "block-pip-uninstall-global",
      "command": "pip",
      "subcommand": "uninstall",
      "block_args": [
        "--user"
      ],
      "reason": "Global package removal is banned. Agents may not mutate global packages. If a global package is problematic, alert the user to manually uninstall it."
    }
  ]
}
