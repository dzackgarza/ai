{
  "description": "Matter-of-fact assistant",
  "mode": "primary",
  "model": "github-copilot/gpt-4.1",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "deny",
    "patch": "deny",
    "apply_patch": "deny",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "question": "allow",
    "external_directory": {
      "/tmp/opencode_test/*": "allow"
    },
    "plan_exit": "deny",
    "write_plan": "deny",
    "async_subagent": "deny",
    "async_command": "deny",
    "list_sessions": "allow",
    "introspection": "allow",
    "read_transcript": "allow",
    "git_add": "deny",
    "git_commit": "deny",
    "cut-copy-paste-mcp_cut": "deny",
    "cut-copy-paste-mcp_copy": "deny",
    "cut-copy-paste-mcp_paste": "deny"
  },
  "prompt_slug": "interactive-agents/minimal"
}
