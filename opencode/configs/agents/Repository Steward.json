{
  "description": "Repo steward - autonomous repository maintenance and optimization",
  "mode": "primary",
  "model": "github-copilot/gpt-4.1",
  "permission": {
    "read": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "list": {
      "*": "allow"
    },
    "edit": {
      "*": "deny"
    },
    "patch": {
      "*": "deny"
    },
    "apply_patch": {
      "*": "deny"
    },
    "bash": "deny",
    "webfetch": "allow",
    "websearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "question": "allow",
    "external_directory": "deny",
    "plan_exit": "allow",
    "write_plan": "allow",
    "async_subagent": "deny",
    "async_command": "deny",
    "list_sessions": "allow",
    "introspection": "allow",
    "read_transcript": "allow",
    "git_add": "deny",
    "git_commit": "deny",
    "cut-copy-paste-mcp_cut": {
      "*": "deny"
    },
    "cut-copy-paste-mcp_copy": {
      "*": "deny"
    },
    "cut-copy-paste-mcp_paste": {
      "*": "deny"
    }
  },
  "prompt_slug": "interactive-agents/repository-steward"
}
