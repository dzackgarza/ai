{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "groq",
    "mistral",
    "cloudflare-ai-gateway",
    "cloudflare-workers-ai"
  ],
  "formatter": {
    "ruff-check": {
      "command": [
        "uvx",
        "ruff",
        "check",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "ruff-format": {
      "command": [
        "uvx",
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".html",
        ".css",
        ".json",
        ".yaml",
        ".yml"
      ]
    }
  },
  "lsp": {
    "texlab": {
      "command": [
        "texlab"
      ],
      "extensions": [
        ".tex",
        ".sty",
        ".cls",
        ".bib"
      ]
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "cut-copy-paste-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@fastmcp-me/cut-copy-paste-mcp"
      ]
    },
    "deepwiki-mcp": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    }
  },
  "model": "github-copilot/gpt-4.1",
  "default_agent": "Interactive",
  "experimental": {
    "openTelemetry": true
  },
  "plugin": [
    "opencode-anthropic-auth@0.0.13",
    "opencode-qwencode-auth@1.3.0",
    "opencode-openai-codex-auth@4.4.0",
    "cc-safety-net@0.7.1",
    "@azumag/opencode-rate-limit-fallback@1.70.0",
    "@ramtinj95/opencode-tokenscope@1.5.2",
    "@dzackgarza/opencode-plugin-improved-task@git+https://github.com/dzackgarza/opencode-plugin-improved-task.git#e4355344fbe5f0590ed13424918d730d04a56aec",
    "@dzackgarza/opencode-plugin-improved-todowrite@git+https://github.com/dzackgarza/opencode-plugin-improved-todowrite.git#061566f8bb2ea6f663e50ef4ccd11e9c2be4d7f7",
    "@dzackgarza/opencode-plugin-improved-webtools@git+https://github.com/dzackgarza/opencode-plugin-improved-webtools.git#d34e7cbb7534bcff729c404aa6bcab9036c812a1",
    "@dzackgarza/opencode-plugin-prompt-transformer@git+https://github.com/dzackgarza/opencode-plugin-prompt-transformer.git#ad9b30c9a3eca8556ba8ddcc7d0feb6c361235d4",
    "@dzackgarza/opencode-plugin-reminder-injection@git+https://github.com/dzackgarza/opencode-plugin-reminder-injection.git#c9a8c76c7444f33baaaead17a2d8bfa73a058cf7",
    "@dzackgarza/opencode-postgres-memory-plugin@git+https://github.com/dzackgarza/opencode-postgres-memory-plugin.git#4a14d102699667bd874b8550b14c8cdeef0259d9",
    "@dzackgarza/opencode-time-travel-plugin@git+https://github.com/dzackgarza/opencode-time-travel-plugin.git#fbd33f84d611afb98bc8fb49409aeb8d531b24ea",
    "@dzackgarza/opencode-zotero-plugin@git+https://github.com/dzackgarza/opencode-zotero-plugin.git#e0c69b080e2251ab9dc3c2fabf3769ce6664ce25",
    "file:///home/dzack/ai/opencode/tools/canonical-plugin-probes/canonical-smoke-fileproof.ts",
    "file:///home/dzack/ai/opencode/tools/canonical-plugin-probes/canonical-shadowing-fileproof.ts",
    "opencode-pty@0.2.3"
  ],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "deny",
    "patch": "deny",
    "apply_patch": "deny",
    "bash": "deny",
    "webfetch": "allow",
    "websearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "question": "allow",
    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow"
    },
    "plan_exit": "deny",
    "write_plan": "deny",
    "async_subagent": "deny",
    "async_command": "deny",
    "list_sessions": "allow",
    "introspection": "allow",
    "read_transcript": "allow",
    "git_add": "deny",
    "git_commit": "deny",
    "cut-copy-paste-mcp_cut": "deny",
    "cut-copy-paste-mcp_copy": "deny",
    "cut-copy-paste-mcp_paste": "deny",
    "serena_read_file": "deny",
    "serena_list_dir": "deny",
    "serena_find_file": "deny",
    "serena_search_for_pattern": "deny",
    "serena_get_symbols_overview": "deny",
    "serena_find_symbol": "deny",
    "serena_find_referencing_symbols": "deny",
    "serena_create_text_file": "deny",
    "serena_replace_content": "deny",
    "serena_replace_symbol_body": "deny",
    "serena_insert_after_symbol": "deny",
    "serena_insert_before_symbol": "deny",
    "serena_rename_symbol": "deny",
    "serena_delete_lines": "deny",
    "serena_insert_at_line": "deny",
    "serena_replace_lines": "deny",
    "serena_read_memory": "allow",
    "serena_list_memories": "allow",
    "serena_write_memory": "allow",
    "serena_edit_memory": "allow",
    "serena_delete_memory": "allow",
    "serena_rename_memory": "allow",
    "serena_activate_project": "allow",
    "serena_check_onboarding_performed": "allow",
    "serena_get_current_config": "allow",
    "serena_onboarding": "deny",
    "serena_prepare_for_new_conversation": "deny",
    "serena_initial_instructions": "deny",
    "serena_think_about_collected_information": "deny",
    "serena_think_about_task_adherence": "deny",
    "serena_think_about_whether_you_are_done": "deny",
    "serena_execute_shell_command": "deny"
  }
}
