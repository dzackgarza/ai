{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "groq",
    "mistral",
    "cloudflare-ai-gateway",
    "cloudflare-workers-ai"
  ],
  "formatter": {
    "ruff-check": {
      "command": [
        "uvx",
        "ruff",
        "check",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "ruff-format": {
      "command": [
        "uvx",
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".html",
        ".css",
        ".json",
        ".yaml",
        ".yml"
      ]
    }
  },
  "lsp": {
    "texlab": {
      "command": [
        "texlab"
      ],
      "extensions": [
        ".tex",
        ".sty",
        ".cls",
        ".bib"
      ]
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "cut-copy-paste-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@fastmcp-me/cut-copy-paste-mcp"
      ]
    },
    "tavily-remote": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}"
    }
  },
  "model": "opencode/minimax-m2.5-free",
  "default_agent": "Interactive",
  "experimental": {
    "openTelemetry": true
  },
  "plugin": [
    "opencode-antigravity-auth@latest",
    "opencode-anthropic-auth@latest",
    "opencode-qwencode-auth@latest",
    "opencode-openai-codex-auth@latest",
    "cc-safety-net@latest",
    "@azumag/opencode-rate-limit-fallback@latest",
    "@ramtinj95/opencode-tokenscope@latest"
  ]
}
