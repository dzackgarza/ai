{
  "enabled": true,
  "headlessOnRateLimit": "abort",
  "cooldownMs": 1000,
  "fallbackMode": "cycle",
  "maxSubagentDepth": 0,
  "enableSubagentFallback": false,
  "fallbackModels": [
    {
      "providerID": "openai",
      "modelID": "gpt-5.3-codex"
    }
  ],
  "retryPolicy": {
    "maxRetries": 1,
    "strategy": "exponential",
    "baseDelayMs": 1000,
    "maxDelayMs": 3000,
    "jitterEnabled": true,
    "jitterFactor": 0.1,
    "timeoutMs": 60000
  },
  "metrics": {
    "enabled": true,
    "output": {
      "console": true,
      "format": "pretty"
    },
    "resetInterval": "daily"
  },
  "circuitBreaker": {
    "enabled": true,
    "failureThreshold": 5,
    "recoveryTimeoutMs": 60000,
    "halfOpenMaxCalls": 1,
    "successThreshold": 2
  },
  "configReload": {
    "enabled": true,
    "watchFile": true,
    "debounceMs": 1000,
    "notifyOnReload": true
  }
}
