{
  "enabled": true,
  "headlessOnRateLimit": "abort",
  "cooldownMs": 10000,
  "fallbackMode": "cycle",
  "maxSubagentDepth": 10,
  "enableSubagentFallback": true,
  "fallbackModels": [
    {
      "providerID": "nvidia",
      "modelID": "qwen/qwen3-coder-480b-a35b-instruct"
    },
    {
      "providerID": "nvidia",
      "modelID": "z-ai/glm5"
    },
    {
      "providerID": "nvidia",
      "modelID": "openai/gpt-oss-120b"
    },
    {
      "providerID": "nvidia",
      "modelID": "stepfun-ai/step-3.5-flash"
    },
    {
      "providerID": "opencode",
      "modelID": "trinity-large-preview-free"
    },
    {
      "providerID": "opencode",
      "modelID": "minimax-m2.5-free"
    },
    {
      "providerID": "opencode",
      "modelID": "big-pickle"
    },
    {
      "providerID": "ollama-cloud",
      "modelID": "deepseek-v3.2"
    },
    {
      "providerID": "github-copilot",
      "modelID": "gpt-5-mini"
    },
    {
      "providerID": "github-copilot",
      "modelID": "gpt-5.1-codex-mini"
    }
  ],
  "retryPolicy": {
    "maxRetries": 10,
    "strategy": "exponential",
    "baseDelayMs": 1000,
    "maxDelayMs": 30000,
    "jitterEnabled": true,
    "jitterFactor": 0.1,
    "timeoutMs": 60000
  },
  "metrics": {
    "enabled": true,
    "output": {
      "console": true,
      "format": "pretty"
    },
    "resetInterval": "daily"
  },
  "circuitBreaker": {
    "enabled": true,
    "failureThreshold": 5,
    "recoveryTimeoutMs": 60000,
    "halfOpenMaxCalls": 1,
    "successThreshold": 2
  },
  "configReload": {
    "enabled": true,
    "watchFile": true,
    "debounceMs": 1000,
    "notifyOnReload": true
  }
}
