# Plugin development recipes
# Usage: just <recipe>

# Show available recipes
default:
    @just --list

# Type-check all plugins (no emit)
typecheck:
    bunx tsc --noEmit

# Run unit tests
test:
    bun test \
        tests/unit/ \
        examples/command-interceptor/command-interceptor.test.ts \
        examples/prompt-router/tests/prompt-router.test.ts

# Compile all plugins (crash = broken import or syntax)
compile:
    bun build --target bun --outdir /tmp/plugin-check \
        write_plan.ts \
        plan_exit.ts \
        sleep.ts \
        async-command.ts \
        introspection.ts \
        list-sessions.ts \
        read-transcript.ts \
        git-add.ts \
        git-commit.ts

# Run classifier test suite against default model
classifier:
    bun run examples/prompt-router/tests/classifier/run.ts

# Run classifier against a specific model
# Usage: just classifier-model groq/llama-3.3-70b-versatile
classifier-model model:
    bun run examples/prompt-router/tests/classifier/run.ts {{model}}

# Run classifier with MD_JSON mode (for models that reject json_object)
# Usage: just classifier-mdjson nvidia/mistralai/mistral-large-3-675b-instruct-2512
classifier-mdjson model:
    bun run examples/prompt-router/tests/classifier/run.ts {{model}} --mode MD_JSON

# Run a single behavioral tier (routing on)
# Usage: just behavior A
behavior tier:
    PROMPT_ROUTER_ENABLED=true bash examples/prompt-router/tests/behavior/run.sh {{tier}}

# Run a single behavioral tier (routing off — baseline)
# Usage: just baseline A
baseline tier:
    PROMPT_ROUTER_ENABLED=false bash examples/prompt-router/tests/behavior/run.sh {{tier}}

# Run all checks: typecheck + test + compile
check: typecheck test compile

# Session management harness
# Usage: just session <command> [args]
# Examples:
#   just session list
#   just session list --limit 10
#   just session stats
session *args:
    bun run utilities/harness/session-harness.ts {{args}}

# Consolidated callback interaction check across task + sleep + async_command
callback-integration:
    bun test tests/unit/callback-integration.test.ts
