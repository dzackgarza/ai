{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@webfetch-handlers": ["webfetch-handlers/index.ts"],
      "@webfetch-handlers/*": ["webfetch-handlers/*"]
    },
    "lib": ["ESNext"],
    "types": ["bun-types"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "*.ts",
    "webfetch-handlers/**/*.ts",
    "stop_hooks/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "examples"
  ]
}
