{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "google_search": "deny",
    "task": "deny"
  },
  "formatter": {
    "ruff-check": {
      "command": ["uvx", "ruff", "check", "--fix", "$FILE"],
      "extensions": [".py"]
    },
    "ruff-format": {
      "command": ["uvx", "ruff", "format", "$FILE"],
      "extensions": [".py"]
    },
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [
        ".md",
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".html",
        ".css",
        ".json",
        ".yaml",
        ".yml"
      ]
    }
  },
  "lsp": {
    "texlab": {
      "command": ["texlab"],
      "extensions": [".tex", ".sty", ".cls", ".bib"]
    }
  },
  "mcp": {
    "serena": {
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "type": "local"
    },
    "kindly": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/Shelpuk-AI-Technology-Consulting/kindly-web-search-mcp-server",
        "kindly-web-search-mcp-server",
        "start-mcp-server"
      ]
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "cut-copy-paste-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@fastmcp-me/cut-copy-paste-mcp"]
    },
    "morph-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@morphllm/morphmcp",
        "--api-key",
        "REDACTED_API_KEY"
      ],
      "enabled": true,
      "environment": {
        "MORPH_API_KEY": "REDACTED_API_KEY",
        "ENABLED_TOOLS": "edit_file,warpgrep_codebase_search"
      }
    }
  },
