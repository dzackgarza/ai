_dag-render target="plans/features" out="plans/plan-dag.md":
  import re
  from pathlib import Path
  from typing import Any, Dict, List, Tuple

  from yaml import safe_load

  def load_frontmatter(md_path: Path) -> Dict[str, Any] | None:
      text = md_path.read_text(encoding="utf-8")
      match = re.match(r"^---\r?\n(.*?)\r?\n---\r?\n?", text, flags=re.S)
      if not match:
          raise ValueError(f"{md_path}: missing YAML frontmatter")
      parsed = safe_load(match.group(1))
      if parsed is None or not isinstance(parsed, dict):
          raise ValueError(f"{md_path}: frontmatter is not a mapping")
      return parsed

  def safe_node(node_id: str) -> str:
      sanitized = re.sub(r"[^A-Za-z0-9_]", "_", node_id.strip())
      if not sanitized:
          sanitized = "node"
      if sanitized[0].isdigit():
          sanitized = f"n_{sanitized}"
      return sanitized

  def quote(text: str) -> str:
      return text.replace("\\", "\\\\").replace('"', '\\"').replace("\n", " ")

  target = Path("{{target}}")
  out_path = Path("{{out}}")
  out_path.parent.mkdir(parents=True, exist_ok=True)

  nodes: Dict[str, Dict[str, str]] = {}
  dependency_edges: List[Tuple[str, str, str]] = []
  containment_edges: List[Tuple[str, str, str]] = []
  records: List[Tuple[str, Dict[str, Any]]] = []

  def normalize_dependency(value: str) -> str:
      value = value.strip()
      if value.startswith("[[") and value.endswith("]]"):
          return value[2:-2]
      return value

  def normalize_status(value: str) -> str:
      value = str(value).strip().lower()
      value = re.sub(r"[^a-z0-9]+", "_", value).strip("_")
      if not value:
          raise ValueError("Missing status")
      return f"status_{value}"

  def node_group(node_id: str) -> str:
      info = nodes.get(node_id)
      if info is None:
          raise ValueError(f"Unknown node '{node_id}'")
      tracker_type = info.get("type")
      if tracker_type not in {"feature", "spec", "plan", "phase", "task", "decision"}:
          raise ValueError(f"Node '{node_id}' has unknown tracker type '{tracker_type}'")
      return tracker_type

  group_labels = {
      "feature": "Features",
      "spec": "Specs",
      "plan": "Plans",
      "phase": "Phases",
      "task": "Tasks",
      "decision": "Decisions",
  }

  if not target.is_dir():
      raise NotADirectoryError(target)

  for md in target.rglob("*.md"):
      if not md.is_file():
          continue
      fm = load_frontmatter(md)
      raw_id = fm.get("id")
      if not isinstance(raw_id, str) or not raw_id.strip():
          raise ValueError(f"{md}: missing or invalid id; required identifier")

      node_id = normalize_dependency(raw_id)
      if node_id != md.stem:
          raise ValueError(f"{md}: id '{node_id}' does not match filename '{md.stem}'")
      records.append((node_id, fm))

      tracker_status = fm.get("trackerStatus")
      if not isinstance(tracker_status, dict) or not isinstance(tracker_status.get("type"), str):
          raise ValueError(f"{md}: missing or invalid trackerStatus.type")

      status = fm.get("status")
      if not isinstance(status, str) or not status.strip():
          raise ValueError(f"{md}: missing or invalid status")

      if node_id in nodes:
          raise ValueError(f"{md}: duplicate id '{node_id}'")

      nodes[node_id] = {"label": node_id, "status": status, "type": tracker_status["type"]}

  for node_id, fm in records:
      depends_on = fm.get("dependsOn", []) or []
      if isinstance(depends_on, str):
          depends_on = [depends_on]
      parents = fm.get("parents", []) or []
      if isinstance(parents, str):
          parents = [parents]

      for raw_dep in depends_on:
          if isinstance(raw_dep, str):
              target_id = normalize_dependency(raw_dep)
              if target_id not in nodes:
                  raise ValueError(f"{node_id}: dependsOn references unknown id '{target_id}'")
              dependency_edges.append((target_id, node_id, "depends"))

      for raw_parent in parents:
          if isinstance(raw_parent, str):
              target_id = normalize_dependency(raw_parent)
              if target_id not in nodes:
                  raise ValueError(f"{node_id}: parents references unknown id '{target_id}'")
              containment_edges.append((target_id, node_id, "parent"))

  status_palette: Dict[str, str] = {
      "status_needs_review": "fill:#fff1c2,stroke:#d97706,color:#7c2d12",
      "status_in_progress": "fill:#d7f3ff,stroke:#0284c7,color:#0f172a",
      "status_unstarted": "fill:#eef2f7,stroke:#64748b,color:#334155",
      "status_complete": "fill:#d8f5e7,stroke:#16a34a,color:#14532d",
      "status_done": "fill:#d8f5e7,stroke:#16a34a,color:#14532d",
      "status_approved_and_unstarted": "fill:#d9f0ff,stroke:#0ea5e9,color:#0c4a6e",
      "status_revision_required": "fill:#fff7ed,stroke:#f59e0b,color:#7c2d12",
      "status_blocked": "fill:#fee2e2,stroke:#dc2626,color:#7f1d1d",
      "status_decided": "fill:#d8f5e7,stroke:#16a34a,color:#14532d",
      "status_implemented": "fill:#d8f5e7,stroke:#16a34a,color:#14532d",
  }

  def build_graph(node_ids: List[str], graph_edges: List[Tuple[str, str, str]], graph_direction: str) -> List[str]:
      lines = [f"graph {graph_direction}"]
      id_map: Dict[str, str] = {}
      status_classes = set()
      group_nodes: Dict[str, List[str]] = {}

      for idx, node_id in enumerate(node_ids):
          safe = safe_node(node_id)
          while safe in id_map.values():
              idx += 1
              safe = safe_node(f"{node_id}_{idx}")
          id_map[node_id] = safe
          group = node_group(node_id)
          group_nodes.setdefault(group, []).append(node_id)
          info = nodes[node_id]
          status_classes.add(normalize_status(info["status"]))

      for group in ["feature", "spec", "plan", "phase", "task", "decision"]:
          members = group_nodes.get(group, [])
          if not members:
              continue
          lines.append(f'  subgraph {safe_node(f"group_{group}")}["{group_labels[group]}"]')
          lines.append("    direction TB")
          for node_id in members:
              safe = id_map[node_id]
              info = nodes[node_id]
              status_class = normalize_status(info["status"])
              lines.append(f'    {safe}["{quote(info["label"])} [{quote(info["status"])}]"]')
              lines.append(f"    class {safe} internal-link")
              lines.append(f"    class {safe} {status_class}")
          lines.append("  end")

      for src, dst, _ in graph_edges:
          if src in id_map and dst in id_map:
              lines.append(f"  {id_map[src]} --> {id_map[dst]}")

      for status_class in sorted(status_classes):
          if status_class not in status_palette:
              raise ValueError(f"Unknown status class '{status_class}'")
          style = status_palette[status_class]
          lines.append(f"  classDef {status_class} {style}")

      return lines

  node_ids = [node_id for node_id, _ in records]
  dependency_lines = build_graph(node_ids, dependency_edges, "LR")
  containment_lines = build_graph(node_ids, containment_edges, "LR")

  md_lines = [
      "# Dependency DAG",
      "```mermaid",
      *dependency_lines,
      "```",
      "",
      "# Containment DAG",
      "```mermaid",
      *containment_lines,
      "```",
  ]
  out_path.write_text("\n".join(md_lines) + "\n", encoding="utf-8")
  print(f"Wrote DAG to {out_path}")

