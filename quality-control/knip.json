{
  "entry": ["src/index.ts", "src/**/*.ts", "app.tsx", "lib/**/*.ts"],
  "project": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "widget/**/*.tsx",
    "services/**/*.ts",
    "app.tsx"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/@girs/**",
    "**/__stubs__/**",
    "**/env.d.ts",
    "**/*.tsx"
  ],
  "ignoreDependencies": ["gi", "@girs", "@logtape/logtape", "@ags/shared"],
  "ignoreExportsUsedInFile": true
}
