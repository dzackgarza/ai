set shell := ["bash", "-euo", "pipefail", "-c"]

control_repo := env_var("GITHUB_WORKSPACE")
reviewer_home := "/home/reviewer"
reviewer_repo := "/home/reviewer/repo"
reviewer_bin := "/home/reviewer/bin"
private_tools := "/opt/ai-review/private"
public_tools := "/opt/ai-review/bin"

install-uv:
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

install-just:
    VERSION=$(curl -sL https://api.github.com/repos/casey/just/releases/latest | jq -r '.tag_name')
    curl -sL "https://github.com/casey/just/releases/download/${VERSION}/just-${VERSION}-x86_64-unknown-linux-musl.tar.gz" \
      | tar -xzf - -C /usr/local/bin just

install-opencode:
    npm install -g opencode-ai

install-cc-safety-net:
    npm install -g cc-safety-net

install-tools: install-uv install-opencode install-cc-safety-net

configure-opencode skill_list:
    mkdir -p ~/.config/opencode
    cp {{control_repo}}/quality-control/ci-opencode.json ~/.config/opencode/opencode.json
    mkdir -p ~/.config/opencode/skills
    for skill in {{skill_list}}; do \
      [ -d "{{control_repo}}/opencode/skills/$skill" ] && cp -r "{{control_repo}}/opencode/skills/$skill" ~/.config/opencode/skills/; \
      echo "installed $skill"; \
    done

configure-cc-safety-net:
    mkdir -p .cc-safety-net/rules/project-rules
    cp {{control_repo}}/quality-control/ci-cc-safety-net-rules.json .cc-safety-net/rules/rule.json
    cp {{control_repo}}/quality-control/ci-cc-safety-net.json .cc-safety-net/rules/project-rules/rulebook.json
    CC_SAFETY_NET_PARANOID=1 npx -y cc-safety-net rule sync

configure-general:
    just configure-opencode "policy-index test-guidelines bespoke-software-policy tool-provisioning-and-environment-hygiene"
    just configure-cc-safety-net

configure-slop:
    just configure-opencode "anti-slop reviewing-llm-code fixing-slop policy-index test-guidelines bespoke-software-policy tool-provisioning-and-environment-hygiene"
    just configure-cc-safety-net

fetch-context category output:
    uv run {{control_repo}}/quality-control/ci/fetch-reviewer-context.py \
      --repo "${GITHUB_REPOSITORY}" \
      --categories "{{category}}" \
      --output "{{control_repo}}/{{output}}"

create-reviewer-user:
    sudo useradd -m -s /bin/bash reviewer || true
    sudo mkdir -p {{reviewer_home}}
    sudo chown reviewer:reviewer {{reviewer_home}}

install-private-review-tools:
    sudo rm -rf {{private_tools}} {{public_tools}}
    sudo mkdir -p {{private_tools}} {{public_tools}}

    sudo cp {{control_repo}}/quality-control/ci/locked/submit-candidate {{private_tools}}/submit-candidate
    sudo cp {{control_repo}}/quality-control/ci/locked/check-report.py {{private_tools}}/check-report.py
    sudo cp {{control_repo}}/quality-control/ci/report-to-sarif.py {{private_tools}}/report-to-sarif.py

    sudo chown -R root:root {{private_tools}}
    sudo chmod 755 {{private_tools}}
    sudo chmod 500 {{private_tools}}/submit-candidate
    sudo chmod 400 {{private_tools}}/check-report.py
    sudo chmod 555 {{private_tools}}/report-to-sarif.py

    printf '#!/bin/sh\nset -eu\nexec sudo -n --preserve-env=REPORT_TYPE,REVIEWER_REPO,CONTROL_REPO /opt/ai-review/private/submit-candidate "$@"\n' \
      | sudo tee {{public_tools}}/submit-candidate >/dev/null

    sudo chown root:root {{public_tools}}/submit-candidate
    sudo chmod 755 {{public_tools}}/submit-candidate

    { echo "reviewer ALL=(root) NOPASSWD: /opt/ai-review/private/submit-candidate"; echo "reviewer ALL=(root) NOPASSWD: /opt/ai-review/private/submit-candidate *"; echo "Defaults!/opt/ai-review/private/submit-candidate env_keep += \"REPORT_TYPE REVIEWER_REPO CONTROL_REPO\""; } | sudo tee /etc/sudoers.d/ai-review-submit

    sudo chmod 0440 /etc/sudoers.d/ai-review-submit
    sudo visudo -c -f /etc/sudoers.d/ai-review-submit

materialize-reviewer-repo:
    sudo rm -rf {{reviewer_repo}}
    sudo mkdir -p {{reviewer_repo}}

    sudo rsync -rl --delete \
      --exclude '.github/workflows' \
      --exclude 'quality-control/ci' \
      --exclude '.review-report-artifact.json' \
      --exclude '.review-report-comment.md' \
      --exclude '.review-report.sarif' \
      {{control_repo}}/ {{reviewer_repo}}/

    sudo cp {{control_repo}}/.reviewer-context.md {{reviewer_repo}}/.reviewer-context.md

    sudo mkdir -p {{reviewer_home}}/.config/opencode
    sudo chown -R reviewer:reviewer {{reviewer_home}}/.config

    sudo chown -R reviewer:reviewer {{reviewer_repo}}

install-reviewer-path:
    sudo mkdir -p {{reviewer_bin}}
    sudo ln -sf {{public_tools}}/submit-candidate {{reviewer_bin}}/submit-candidate
    sudo chown -R reviewer:reviewer {{reviewer_bin}}

prepare-reviewer: create-reviewer-user install-private-review-tools materialize-reviewer-repo install-reviewer-path

run-review mode template report_type:
    sudo -u reviewer -H env \
      HOME={{reviewer_home}} \
      XDG_CONFIG_HOME={{reviewer_home}}/.config \
      PATH="{{reviewer_bin}}:/usr/local/bin:/usr/bin:/bin" \
      REPORT_TYPE="{{report_type}}" \
      REVIEWER_REPO="{{reviewer_repo}}" \
      CONTROL_REPO="{{control_repo}}" \
      bash -lc 'cd {{reviewer_repo}} && python3 quality-control/run-review.py \
        --mode "{{mode}}" \
        --skills-dir opencode/skills \
        --template "{{template}}" \
        --base-ref "${GITHUB_BASE_REF:-main}" \
        --pr-number "${PR_NUMBER:-0}" \
        --reviewer-context .reviewer-context.md'

collect-review-output:
    cp {{reviewer_repo}}/.review-report-artifact.json {{control_repo}}/.review-report-artifact.json
    if [ -f {{reviewer_repo}}/.review-report-comment.md ]; then \
      cp {{reviewer_repo}}/.review-report-comment.md {{control_repo}}/.review-report-comment.md; \
    fi

convert-sarif category:
    uv run {{private_tools}}/report-to-sarif.py \
      --artifact {{control_repo}}/.review-report-artifact.json \
      --output {{control_repo}}/.review-report.sarif \
      --category "{{category}}"
