#!/bin/sh
# Validates the candidate report at the fixed path.
# On success: copies to artifact path and exits 0.
# On failure: prints errors and exits non-zero.
# The agent fixes the same file and re-runs this script.

set -euo pipefail

HERE="$(cd "$(dirname "$0")/../.." && pwd)"
CANDIDATE="$HERE/.agents/review-runner/candidates/submitted.json"
CHECKER="$HERE/quality-control/check-report.py"
RENDERER="$HERE/quality-control/render-review-comment.py"
ARTIFACT="$HERE/.review-report-artifact.json"
COMMENT="$HERE/.review-report-comment.md"

if [ "${1:-}" = "--help" ]; then
    cat <<'HELP'
submit-candidate — validate and submit a review report

Usage:
  quality-control/ci/submit-candidate            # validate and submit (default)
  quality-control/ci/submit-candidate --help     # print this message

Report format (JSON written to .agents/review-runner/candidates/submitted.json):

{
  "schema_version": 1,
  "report_type": "general",
  "repo_sha": "<git-head-sha>",
  "review_scope": [
    "src/main.ts",
    "src/utils.ts"
  ],
  "findings": [
    {
      "tier": "tier1",
      "label": "BLOCKER",
      "category": "semantic-regression",
      "location": {
        "path": "src/foo.ts",
        "start_line": 10,
        "end_line": 25
      },
      "violated_invariant": "The CI runner silently swallows diff-retrieval failures instead of aborting",
      "proof_command": "grep -rn 'get_diff' quality-control/run-review.py",
      "symptom": "...",
      "source": "...",
      "consequence": "...",
      "remedy": "...",
      "evidence": [
        {"kind": "file-read", "path": "src/foo.ts", "lines": [1, 80]}
      ]
    }
  ],
  "checked_surfaces": [
    {
      "path": "src/foo.ts",
      "reason": "high-churn",
      "lines_read": [1, 120],
      "result": "finding"
    }
  ],
  "rejected_easy_wins": []
}

report_type must be "general" or "slop".

--- Rejection Rules ---

These cause immediate rejection. Learn them now — don't submit twice:

BAD: {"violated_invariant": "clean code"}
GOOD: {"violated_invariant": "The CI runner silently swallows diff-retrieval failures instead of aborting"}

  * violated_invariant must name a specific violated behavior or contract (>=20 chars).
    Blanket claims rejected: clean code, looks fine, nothing to report, no violations,
    appears correct, everything looks fine, no issues found.
  * proof_command must be a real command or code-path proving the violation (>=10 chars).

  * score and report fields are NOT ALLOWED. The renderer computes score from findings
    and builds comment markdown automatically. JSON with either field is rejected.

  * category values containing 'infra', 'infrastructure', 'ci', 'workflow', or 'config'
    are rejected. Categories describe the defect type (semantic-regression, incorrect-output,
    test-quality, etc.), not CI infrastructure.

  * Low-signal categories (code-style, naming, formatting, file-length, readability,
    comment-style, duplication, etc.) MUST be tier2. Tier 1 findings must be substantive.

  * At least one finding must be substantive (Tier 1 or non-low-signal category).
    All-tier2-low-signal is rejected.

  * finding.location.path may not be in .github/, .agents/, quality-control/, or
    opencode/skills/. Findings target source and test files in the PR diff, not
    infrastructure.

  * Every path in review_scope, location.path, and evidence[].path must exist in git
    at repo_sha. Check 'git cat-file -e <sha>:<path>' before submitting.

All rejection rules produce error messages with 'FIX:' guidance on what to change.
HELP
    exit 0
fi

if ! [ -f "$CANDIDATE" ]; then
    echo "ERROR: No report found at $CANDIDATE"
    echo "Write your report to $CANDIDATE first, then run this script."
    exit 1
fi

if uv run "$CHECKER" "$CANDIDATE" 2>&1; then
    cp "$CANDIDATE" "$ARTIFACT"
    uv run "$RENDERER" "$ARTIFACT" > "$COMMENT"
    echo "Report validated and comment rendered to $COMMENT"
    exit 0
fi
exit 1
