_sage-syntax:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: Sage syntax validation ==="
	echo "# Preparses .sage files and byte-compiles the generated Python to catch syntax errors early"
	mapfile -t sage_files < <(just --justfile {{justfile()}} -d . _sage-qc-files)
	if [ "${#sage_files[@]}" -eq 0 ]; then
		echo "Skipping Sage syntax validation: no Sage files found."
		exit 0
	fi

	sage_bin="${SAGE_BIN:-sage}"
	if ! command -v "$sage_bin" >/dev/null 2>&1; then
		echo "ERROR: .sage files found, but Sage is unavailable. Set SAGE_BIN or put sage on PATH."
		exit 1
	fi

	sage_preparse_dir="$(mktemp -d "${TMPDIR:-/tmp}/qc-sage-syntax.XXXXXX")"
	trap 'rm -rf "$sage_preparse_dir"' EXIT
	echo "# Preparsing and compiling ${#sage_files[@]} Sage file(s)"
	copied_sage_files=()
	compile_args=()
	failed=0
	for sage_file in "${sage_files[@]}"; do
		target="$sage_preparse_dir/$sage_file"
		mkdir -p "$(dirname "$target")"
		cp "$sage_file" "$target"
		generated_file="$target.py"
		copied_sage_files+=("$sage_file")
		compile_args+=("$sage_file" "$generated_file")
	done

	(
		cd "$sage_preparse_dir"
		"$sage_bin" --preparse "${copied_sage_files[@]}" >/dev/null
	)

	for sage_file in "${sage_files[@]}"; do
		generated_file="$sage_preparse_dir/$sage_file.py"
		if [ ! -f "$generated_file" ]; then
			echo "ERROR: Sage preparse did not produce $generated_file for $sage_file"
			failed=1
		fi
	done
	if [ "$failed" -ne 0 ]; then
		exit 1
	fi

	if ! "$sage_bin" -python - "${compile_args[@]}" <<'PY'
	import py_compile
	import sys

	args = sys.argv[1:]
	failed = False
	for index in range(0, len(args), 2):
	    original = args[index]
	    generated = args[index + 1]
	    try:
	        py_compile.compile(generated, doraise=True)
	    except py_compile.PyCompileError as exc:
	        print(exc.msg, file=sys.stderr, end="" if exc.msg.endswith("\n") else "\n")
	        print(f"ERROR: Sage syntax validation failed for {original}", file=sys.stderr)
	        failed = True

	raise SystemExit(1 if failed else 0)
	PY
	then
		exit 1
	fi

_no-bypass:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: bypass comment detection (no pragma/noqa/type:ignore) ==="
	echo "# Blocks staged changes from hiding QC issues via bypass comments (# pragma: no cover, // istanbul ignore, # noqa, # type: ignore, @ts-ignore, @ts-expect-error, // eslint-disable)"
	# Block attempts to hide/launder QC issues via bypass comments
	files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
	[ -z "$files" ] && exit 0
	for file in $files; do
		[ -f "$file" ] || continue
		# Python coverage bypass
		if grep -n "# pragma: no cover" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# pragma: no cover' — fix coverage, don't hide it"
			exit 1
		fi
		# JS coverage bypass
		if grep -n "// istanbul ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// istanbul ignore' — fix coverage, don't hide it"
			exit 1
		fi
		# Python lint bypass
		if grep -n "# noqa" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# noqa' — fix lint errors, don't hide them"
			exit 1
		fi
		# Python type bypass
		if grep -n "# type: ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# type: ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS bypass
		if grep -n "@ts-ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS expect-error without comment
		if grep -n "@ts-expect-error$" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-expect-error' without justification — add a comment explaining why"
			exit 1
		fi
		# ESLint bypass
		if grep -n "// eslint-disable" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// eslint-disable' — fix lint errors, don't hide them"
			exit 1
		fi
	done
	echo "No bypass comments detected in staged files"

