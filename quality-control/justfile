# justfile for Python quality control
#
# PURPOSE OF A JUSTFILE:
# 1) ENSHRINE WORKFLOWS: Every workflow lives in the justfile. No ad-hoc
#    scripts, no "I'll just run this command directly". Justfile is the
#    single source of truth for project operations.
# 2) FIX OPINIONATED WORKFLOWS: Agents cannot cherry-pick checks. For
#    example, `just typecheck` does NOT assert code quality — the `test`
#    recipe runs the full QC stack (coverage, complexity, dead code,
#    duplication, etc). Running only typecheck is insufficient.
# 3) ABSTRACT COMPLEXITY: Env management, sandbox setup, tool installation,
#    common tasks — all hidden in private recipes. Users run workflows,
#    not infrastructure.
#
# MINIMAL QUALITY CONTROL: This justfile encodes the minimal QC stack
# that MUST be present in every Python project. The `test` recipe is
# the single entry point — run `just test` always. Do NOT bypass it.
#
# NARROW PUBLIC SURFACE: Only expose essential public recipes. Encode
# all standard project workflows (build, dev, deploy, db migrate, etc.)
# in justfile recipes — but these are private or grouped separately.
# The `test` recipe's dependency graph is the only thing that gates CI.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory. No symlinks needed. Configs read by each tool:
#   .importlinter  → import-linter (explicit --config flag)
#   .slopconfig.yaml → ai-slop-detector (explicit --config flag)
#   semgrep.yml    → semgrep local rules (explicit --config flag)
#   .jscpd.json    → jscpd (explicit --config flag)
#   .coveragerc    → coverage.py reads .coveragerc from cwd (run from project root)
# GLOBAL CONFIGS OK: vulture, deptry, diff-cover, ruff, black, mypy
# all read from ~/.config/ or pyproject.toml [tool.*] sections.

default:
  @just test

# private recipes (prefix with _ — do not run individually in CI)
_venv:
	#!/usr/bin/env bash
	set -euo pipefail
	uv venv --python 3.11

_install-tools: _venv
	#!/usr/bin/env bash
	set -euo pipefail
	uv pip install coverage diff-cover vulture deptry semgrep lizard import-linter

_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run coverage run -m pytest
	uv run coverage xml -o coverage.xml

_diff-cover: _coverage
	#!/usr/bin/env bash
	set -euo pipefail
	uv run diff-cover coverage.xml --compare-branch ${DIFF_COVER_BASE:-main}

_vulture: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run vulture src tests --min-confidence 60

_deptry: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run deptry check src

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run semgrep --config={{justfile_directory()}}/semgrep.yml --config=p/ci --inline-suppression

_jscpd:
	#!/usr/bin/env bash
	set -euo pipefail
	npx -y jscpd --config {{justfile_directory()}}/.jscpd.json

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run lizard src -l python -C 7 -L 100 -a 5 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*"

_import-linter: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run import-linter check --config {{justfile_directory()}}/.importlinter

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	codeql database create codeql-db --language=python --source-root=.
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif

_slop:
	#!/usr/bin/env bash
	set -euo pipefail
	uvx ai-slop-detector --project . \
		--config {{justfile_directory()}}/.slopconfig.yaml \
		--ci-mode hard \
		--fail-threshold 30 \
		--severity high \
		--ci-claims-strict \
		--ci-report

# top-level test depends on all private analyses
test: _diff-cover _vulture _deptry _semgrep _jscpd _lizard _import-linter _codeql _slop
	#!/usr/bin/env bash
	set -euo pipefail
	echo "All analyses completed"
