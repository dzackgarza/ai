# justfile — Cross-language (shared) quality control recipes
#
# This file contains QC recipes that are language-agnostic.
# Language-specific justfiles import this file and compose its
# recipes into their `test` chain alongside their own recipes.
#
# Language justfiles:
#   justfile-python  — Python QC (imports this file)
#   justfile-bun     — TypeScript QC (imports this file)
#   justfile-rust    — Rust QC (imports this file)
#   justfile-sage    — SageMath QC (imports this file, delegates to Python)
#
# CONFIGS (all in this directory):
#   semgrep.yml       → semgrep local rules (--config flag)
#   .jscpd.json       → jscpd (--config flag)
#   .slopconfig.yaml  → ai-slop-detector (--config flag)

# ── Cross-language recipes ────────────────────────────────────────

_no-bypass:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: bypass comment detection ==="
	echo "# Blocks staged changes from hiding QC issues via bypass comments"
	files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
	[ -z "$files" ] && exit 0
	for file in $files; do
		[ -f "$file" ] || continue
		if grep -n "# pragma: no cover" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# pragma: no cover' — fix coverage, don't hide it"
			exit 1
		fi
		if grep -n "// istanbul ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// istanbul ignore' — fix coverage, don't hide it"
			exit 1
		fi
		if grep -n "# noqa" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# noqa' — fix lint errors, don't hide them"
			exit 1
		fi
		if grep -n "# type: ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# type: ignore' — fix type errors, don't hide them"
			exit 1
		fi
		if grep -nP 'as\s+(unknown|any|never)\s+as\s' "$file" 2>/dev/null; then
			echo "ERROR: $file contains a double-cast bypass (e.g., 'as unknown as') — use a proper type assertion or restructure the code"
			exit 1
		fi
		if grep -n "@ts-ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-ignore' — fix type errors, don't hide them"
			exit 1
		fi
		if grep -n "@ts-expect-error$" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-expect-error' without justification — add a comment explaining why"
			exit 1
		fi
		if grep -n "// eslint-disable" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// eslint-disable' — fix lint errors, don't hide them"
			exit 1
		fi
	done
	echo "No bypass comments detected in staged files"

_check-no-local-qc-override:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: local QC override detection ==="
	echo "# Detects local config files that would override or duplicate global QC"
	failed=0
	# Shared tool configs that must NOT exist in project root.
	# Global QC owns these tool configs — local copies are forbidden overrides.
	for config in \
		semgrep.yml \
		.jscpd.json \
		.slopconfig.yaml \
		sgconfig.yml; do
		if [ -f "$config" ]; then
			echo "ERROR: Local QC override detected: $config — global QC owns this tool config."
			echo "       Remove it and use the global config in ~/ai/quality-control/ instead."
			failed=1
		fi
	done
	if [ "$failed" -ne 0 ]; then
		exit 1
	fi
	echo "No local QC overrides detected"

_semgrep:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: semgrep security pattern scanning ==="
	echo "# Static analysis for code quality and fraud patterns"
	uvx --from semgrep semgrep scan \
		--config={{justfile_directory()}}/semgrep.yml \
		--config=p/ci \
		--exclude=codeql-db \
		--scan-unknown-extensions \
		--autofix
	# --scan-unknown-extensions: scan all file types, not just known ones.
	# The rules in semgrep.yml define which patterns to match.
	# Exit code reflects whether any blocking results were found.

_vibecheck:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: vibecheck anti-slop pattern detection ==="
	echo "# Runs qinnovates/vibecheck-slop-stopper via uvx against the project root"
	uvx --from git+https://github.com/qinnovates/vibecheck-slop-stopper vibecheck . --severity high

_src-files:
	#!/usr/bin/env bash
	set -euo pipefail
	find . -type f \( \
		-name '*.py' -o -name '*.sage' -o \
		-name '*.ts' -o -name '*.tsx' -o \
		-name '*.js' -o -name '*.jsx' -o -name '*.mjs' -o -name '*.cjs' -o \
		-name '*.rs' \) \
		-not -path '*/node_modules/*' \
		-not -path '*/.venv/*' \
		-not -path '*/__pycache__/*' \
		-not -path '*/target/*' \
		-not -path '*/dist/*' \
		-not -path '*/build/*' \
		-not -path '*/codeql-db/*' \
		-not -path '*/.git/*' \
		2>/dev/null

_slop:
	#!/usr/bin/env bash
	set -euo pipefail
	# Preflight: verify the ML model file exists (centrally owned artifact)
	model_file="{{justfile_directory()}}/models/slop_classifier.pkl"
	if [ ! -f "$model_file" ]; then
		echo "ERROR: ai-slop-detector ML model not found: $model_file"
		echo "  Run: uv run scripts/train_slop_model.py"
		echo "  (from the quality-control repo root)"
		exit 1
	fi
	echo "============================="
	echo "=== Running: ai-slop-detector ML-based quality check ==="
	echo "# ML classifier for detecting AI-generated code patterns and low-quality implementations"
	project_root="$(pwd -P)"
	mapfile -t src_files < <(just --justfile {{justfile()}} -d . _src-files 2>/dev/null || true)
	if [ "${#src_files[@]}" -eq 0 ]; then
		echo "ERROR: ai-slop-detector: no source files found in project."
		exit 1
	fi
	for file in "${src_files[@]}"; do
		target="$file"
		if [[ "$target" != /* ]]; then
			target="$project_root/$target"
		fi
		extra_args=""
		if [[ "$target" == *.ts || "$target" == *.tsx || "$target" == *.js || "$target" == *.jsx || "$target" == *.mjs || "$target" == *.cjs ]]; then
			extra_args="--js"
		fi
		(
			cd {{justfile_directory()}}
			uvx ai-slop-detector "$target" $extra_args \
			--config {{justfile_directory()}}/.slopconfig.yaml \
			--verbose \
			--ci-mode hard \
			--ci-claims-strict \
			--ci-report \
			--no-color
		)
	done

# ── Entry Points ──────────────────────────────────────────────────

_global-qc: _no-bypass _check-no-local-qc-override _semgrep _vibecheck _slop
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Global quality checks completed"

_global-qc-ci: _global-qc
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Global CI quality checks completed"
