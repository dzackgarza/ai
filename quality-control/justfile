_mypy: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: mypy type checking ==="
	echo "# Checks static typing after syntax validation and before lint/style normalization"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping mypy: no Python files found."
		exit 0
	fi
	# If the project provides sage-mypy-plugin.ini, merge it with the global config.
	# ConfigParser merge (read_string twice) handles duplicate sections correctly:
	# later keys extend or override earlier ones.  This lets the project ini add
	# [mypy] mypy_path for the plugin's generated stub root without forking the
	# global config.
	global_config="{{justfile_directory()}}/mypy-global.ini"
	if [ -f "sage-mypy-plugin.ini" ]; then
		merged_config=$(mktemp /tmp/mypy-merged-XXXXX.ini)
		trap 'rm -f "$merged_config"' EXIT
		python3 "{{justfile_directory()}}/scripts/merge_ini.py" \
			"$global_config" "sage-mypy-plugin.ini" "$merged_config"
		effective_config="$merged_config"
	else
		effective_config="$global_config"
	fi
	sage_bin="${SAGE_BIN:-sage}"
	if command -v "$sage_bin" >/dev/null 2>&1; then
		"$sage_bin" -python -m mypy \
			--config-file "$effective_config" \
			--ignore-missing-imports \
			--explicit-package-bases \
			"${python_files[@]}"
	else
		uvx --python 3.14 --from mypy mypy \
			--config-file "$effective_config" \
			"${python_files[@]}"
	fi

_normalize: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: ruff format and check (auto-fix) ==="
	echo "# Enforces PEP 8 style + auto-fixes common issues (import sorting, unused imports, pyupgrade patterns)"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping ruff normalization: no Python or Sage files found."
		exit 0
	fi
	if [ -n "${SAGE_PYTEST:-}" ]; then
		sage -python -m ruff check --fix \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
		sage -python -m ruff format \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
	else
		uvx --from ruff ruff check --fix \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
		uvx --from ruff ruff format \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
	fi

_pytest_with_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: pytest with coverage measurement ==="
	echo "# Runs pytest with coverage.py to enforce 100% line/branch coverage and generate coverage.xml"
	if ! rg --files tests -g 'test_*.py' -g '*_test.py' >/dev/null 2>&1; then
		echo "Skipping coverage: no pytest-style Python tests found."
		exit 0
	fi
	if [ ! -f pyproject.toml ]; then
		echo "No pyproject.toml found; running pytest without editable install or coverage."
		uvx --with pytest pytest tests
		exit 0
	fi
	project_root="$(pwd -P)"
	project_slug="$(printf '%s' "$project_root" | sed 's#[^A-Za-z0-9._-]#_#g')"
	coverage_root="${XDG_CACHE_HOME:-$HOME/.cache}/quality-control/coverage/$project_slug"
	coverage_data="$coverage_root/.coverage"
	coverage_xml="$coverage_root/coverage.xml"
	mkdir -p "$coverage_root"
	COVERAGE_FILE="$coverage_data" uvx --from coverage --with pytest --with-editable . coverage run -m pytest
	COVERAGE_FILE="$coverage_data" uvx --from coverage coverage xml --fail-under=100 -o "$coverage_xml"
	echo "Coverage XML report: $coverage_xml"

_diff-cover: _pytest_with_coverage
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: diff-cover against main branch ==="
	echo "# Reports coverage gaps on code changed since main branch to ensure new code is tested"
	project_root="$(pwd -P)"
	project_slug="$(printf '%s' "$project_root" | sed 's#[^A-Za-z0-9._-]#_#g')"
	coverage_xml="${XDG_CACHE_HOME:-$HOME/.cache}/quality-control/coverage/$project_slug/coverage.xml"
	if [ ! -f "$coverage_xml" ]; then
		echo "Skipping diff-cover: no coverage.xml generated at $coverage_xml."
		exit 0
	fi
	uvx --from diff-cover diff-cover "$coverage_xml" --compare-branch ${DIFF_COVER_BASE:-main}

_vulture: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: vulture dead code detection ==="
	echo "# Finds unused code (functions, classes, variables) that can be safely removed"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	mapfile -t sage_files < <(just --justfile {{justfile()}} -d . _sage-qc-files)
	generated_sage_python_files=()
	whitelist_file="{{justfile_directory()}}/vulture_whitelist.py"
	if [ "${#python_files[@]}" -eq 0 ] && [ "${#sage_files[@]}" -eq 0 ]; then
		echo "Skipping vulture: no Python or Sage files found."
		exit 0
	fi

	if [ "${#sage_files[@]}" -gt 0 ]; then
		sage_bin="${SAGE_BIN:-sage}"
		if ! command -v "$sage_bin" >/dev/null 2>&1; then
			echo "ERROR: .sage files found, but Sage is unavailable. Set SAGE_BIN or put sage on PATH."
			exit 1
		fi

		sage_preparse_dir="$(mktemp -d "${TMPDIR:-/tmp}/qc-vulture-sage.XXXXXX")"
		trap 'rm -rf "$sage_preparse_dir"' EXIT
		echo "# Preparsing ${#sage_files[@]} Sage file(s) for vulture"
		copied_sage_files=()
		for sage_file in "${sage_files[@]}"; do
			target="$sage_preparse_dir/$sage_file"
			mkdir -p "$(dirname "$target")"
			cp "$sage_file" "$target"
			copied_sage_files+=("$sage_file")
			generated_sage_python_files+=("$target.py")
		done
		(
			cd "$sage_preparse_dir"
			"$sage_bin" --preparse "${copied_sage_files[@]}" >/dev/null
		)
		for generated_file in "${generated_sage_python_files[@]}"; do
			if [ ! -f "$generated_file" ]; then
				echo "ERROR: Sage preparse did not produce $generated_file"
				exit 1
			fi
		done
	fi

	uvx --from vulture vulture \
		--config {{justfile_directory()}}/pyproject.toml \
		"${python_files[@]}" \
		"${generated_sage_python_files[@]}" \
		"$whitelist_file"

