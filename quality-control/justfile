# justfile for Python quality control
#
# PURPOSE OF A JUSTFILE:
# 1) ENSHRINE WORKFLOWS: Every workflow lives in the justfile. No ad-hoc
#    scripts, no "I'll just run this command directly". Justfile is the
#    single source of truth for project operations.
# 2) FIX OPINIONATED WORKFLOWS: Agents cannot cherry-pick checks. For
#    example, `just typecheck` does NOT assert code quality — the `test`
#    recipe runs the full QC stack. Running only typecheck is insufficient.
# 3) ABSTRACT COMPLEXITY: Env management, sandbox setup, tool installation,
#    common tasks — all hidden in private recipes. Users run workflows,
#    not infrastructure.
#
# WORKFLOW:
#   just test      — local quality checks (linting, static analysis, complexity)
#   just test-ci  — test + live/isolated checks (coverage, diff-cover, integration tests)
#   Both are public. Everything else is private. Do NOT add public recipes.
#
# HOOKS: pre-commit.hook and pre-push.hook both block on `just test`.
#   Copy/symlink into .git/hooks/ to activate.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory. No symlinks needed. Configs read by each tool:
#   .slopconfig.yaml → ai-slop-detector (explicit --config flag)
#   semgrep.yml    → semgrep local rules (explicit --config flag)
#   .jscpd.json    → jscpd (explicit --config flag)
#   .coveragerc    → coverage.py reads .coveragerc from cwd (run from project root)
# GLOBAL CONFIGS OK: vulture, deptry, diff-cover, ruff, black, mypy
# all read from ~/.config/ or pyproject.toml [tool.*] sections.

default:
  @just test

# private recipes (prefix with _ — never run individually)
_no-bypass:
	#!/usr/bin/env bash
	set -euo pipefail
	# Block attempts to hide/launder QC issues via bypass comments
	files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
	[ -z "$files" ] && exit 0
	for file in $files; do
		[ -f "$file" ] || continue
		# Python coverage bypass
		if grep -n "# pragma: no cover" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# pragma: no cover' — fix coverage, don't hide it"
			exit 1
		fi
		# JS coverage bypass
		if grep -n "// istanbul ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// istanbul ignore' — fix coverage, don't hide it"
			exit 1
		fi
		# Python lint bypass
		if grep -n "# noqa" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# noqa' — fix lint errors, don't hide them"
			exit 1
		fi
		# Python type bypass
		if grep -n "# type: ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# type: ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS bypass
		if grep -n "@ts-ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS expect-error without comment
		if grep -n "@ts-expect-error$" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-expect-error' without justification — add a comment explaining why"
			exit 1
		fi
		# ESLint bypass
		if grep -n "// eslint-disable" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// eslint-disable' — fix lint errors, don't hide them"
			exit 1
		fi
	done
	echo "No bypass comments detected in staged files"

_venv:
	#!/usr/bin/env bash
	set -euo pipefail
	uv venv --allow-existing

_install-tools: _venv
	#!/usr/bin/env bash
	set -euo pipefail
	uv pip install coverage diff-cover vulture deptry semgrep lizard import-linter ruff

_normalize: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	if [ ! -f pyproject.toml ]; then
		echo "Skipping ruff normalization: no pyproject.toml found."
		exit 0
	fi
	uv run ruff check --fix .
	uv run ruff format .

_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run coverage run -m pytest
	uv run coverage xml --fail-under=100 -o coverage.xml

_diff-cover: _coverage
	#!/usr/bin/env bash
	set -euo pipefail
	uv run diff-cover coverage.xml --compare-branch ${DIFF_COVER_BASE:-main}

_vulture: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	if [ ! -e src ] && [ ! -e tests ]; then
		echo "Skipping vulture: no src/tests paths found."
		exit 0
	fi
	uv run vulture --config {{justfile_directory()}}/pyproject.toml

_deptry: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run deptry .

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run semgrep scan --config={{justfile_directory()}}/semgrep.yml --config=p/ci --autofix .

_jscpd:
	#!/usr/bin/env bash
	set -euo pipefail
	npx -y jscpd --config {{justfile_directory()}}/.jscpd.json

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run lizard src -l python -C 7 -L 100 -a 5 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*"

_import-linter: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	config=""
	if [ -f .importlinter ]; then
		config=".importlinter"
	elif [ -f pyproject.toml ] && python -c 'import pathlib, sys, tomllib; data = tomllib.loads(pathlib.Path("pyproject.toml").read_text(encoding="utf-8")); tool_section = data.get("tool", {}); sys.exit(0 if ("import-linter" in tool_section or "importlinter" in tool_section) else 1)'
	then
		config="pyproject.toml"
	fi
	if [ -z "$config" ]; then
		echo "Skipping import-linter: no project-specific import-linter config found."
		exit 0
	fi
	uv run lint-imports --config "$config"

_grain:
	#!/usr/bin/env bash
	set -euo pipefail
	cp {{justfile_directory()}}/grain.toml .grain.toml
	uvx --from git+https://github.com/mmartoccia/grain grain check --all --fix
	rm .grain.toml

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	if ! command -v codeql >/dev/null 2>&1; then
		echo "Skipping CodeQL: codeql CLI is not installed."
		exit 0
	fi
	codeql database create codeql-db --overwrite --language=python --source-root=.
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif

_slop:
	#!/usr/bin/env bash
	set -euo pipefail
	uvx ai-slop-detector --project . \
		--config {{justfile_directory()}}/.slopconfig.yaml \
		--verbose \
		--ci-mode hard \
		--ci-claims-strict \
		--ci-report

# public: all static checks run locally
test: _normalize _no-bypass _coverage _diff-cover _vulture _deptry _semgrep _jscpd _lizard _import-linter _codeql _slop _grain
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Local quality checks completed"

# public: test-ci = test + live/isolated checks
# Add project-specific live tests (needs docker, live server, etc.) here
test-ci: test
	#!/usr/bin/env bash
	set -euo pipefail
	echo "CI checks completed"
