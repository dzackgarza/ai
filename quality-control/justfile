# justfile for Python quality control
#
# PURPOSE OF A JUSTFILE:
# 1) ENSHRINE WORKFLOWS: Every workflow lives in the justfile. No ad-hoc
#    scripts, no "I'll just run this command directly". Justfile is the
#    single source of truth for project operations.
# 2) FIX OPINIONATED WORKFLOWS: Agents cannot cherry-pick checks. For
#    example, `just typecheck` does NOT assert code quality — the `test`
#    recipe runs the full QC stack. Running only typecheck is insufficient.
# 3) ABSTRACT COMPLEXITY: Env management, sandbox setup, tool installation,
#    common tasks — all hidden in private recipes. Users run workflows,
#    not infrastructure.
#
# WORKFLOW:
#   just test      — local quality checks (linting, static analysis, complexity)
#   just test-ci  — test + live/isolated checks (coverage, diff-cover, integration tests)
#   Both are public. Everything else is private. Do NOT add public recipes.
#
# HOOKS: pre-commit.hook and pre-push.hook both block on `just test`.
#   Copy/symlink into .git/hooks/ to activate.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory. No symlinks needed. Configs read by each tool:
#   .slopconfig.yaml → ai-slop-detector (explicit --config flag)
#   semgrep.yml    → semgrep local rules (explicit --config flag)
#   .jscpd.json    → jscpd (explicit --config flag)
#   sgconfig.yml   → ast-grep (explicit --config flag)
#   .coveragerc    → coverage.py reads .coveragerc from cwd (run from project root)
# GLOBAL CONFIGS OK: vulture, deptry, diff-cover, ruff, black, mypy
# all read from ~/.config/ or pyproject.toml [tool.*] sections.

default:
  @just test

# private recipes (prefix with _ — never run individually)
_python-qc-files:
	#!/usr/bin/env bash
	set -euo pipefail
	rg --files \
		-g '*.py' \
		-g '!*.sage.py' \
		-g '!**/external/**' \
		-g '!**/node_modules/**' \
		-g '!**/__pycache__/**' \
		-g '!**/.venv/**' \
		-g '!**/dist/**' \
		-g '!**/build/**' \
		-g '!**/coverage/**' \
		-g '!**/codeql-db/**'

_no-bypass:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: bypass comment detection (no pragma/noqa/type:ignore) ==="
	echo "# Blocks staged changes from hiding QC issues via bypass comments (# pragma: no cover, // istanbul ignore, # noqa, # type: ignore, @ts-ignore, @ts-expect-error, // eslint-disable)"
	# Block attempts to hide/launder QC issues via bypass comments
	files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
	[ -z "$files" ] && exit 0
	for file in $files; do
		[ -f "$file" ] || continue
		# Python coverage bypass
		if grep -n "# pragma: no cover" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# pragma: no cover' — fix coverage, don't hide it"
			exit 1
		fi
		# JS coverage bypass
		if grep -n "// istanbul ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// istanbul ignore' — fix coverage, don't hide it"
			exit 1
		fi
		# Python lint bypass
		if grep -n "# noqa" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# noqa' — fix lint errors, don't hide them"
			exit 1
		fi
		# Python type bypass
		if grep -n "# type: ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# type: ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS bypass
		if grep -n "@ts-ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS expect-error without comment
		if grep -n "@ts-expect-error$" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-expect-error' without justification — add a comment explaining why"
			exit 1
		fi
		# ESLint bypass
		if grep -n "// eslint-disable" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// eslint-disable' — fix lint errors, don't hide them"
			exit 1
		fi
	done
	echo "No bypass comments detected in staged files"

_venv:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: uvx/npx tool runners setup ==="
	echo "# Provides access to ruff, coverage, semgrep, and other Python/JS tools via uvx/npx without local installation"

_install-tools: _venv
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: tool installation ==="
	echo "# Installs Python/JS tool dependencies to local cache for faster subsequent runs"

_normalize: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: ruff format and check (auto-fix) ==="
	echo "# Enforces PEP 8 style + auto-fixes common issues (import sorting, unused imports, pyupgrade patterns)"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping ruff normalization: no Python or Sage files found."
		exit 0
	fi
	if [ -n "${SAGE_PYTEST:-}" ]; then
		sage -python -m ruff check --fix \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
		sage -python -m ruff format \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
	else
		uvx --from ruff ruff check --fix \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
		uvx --from ruff ruff format \
			--config {{justfile_directory()}}/ruff-global.toml \
			--extension sage:python \
			"${python_files[@]}"
	fi

_pytest_with_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: pytest with coverage measurement ==="
	echo "# Runs pytest with coverage.py to enforce 100% line/branch coverage and generate coverage.xml"
	if [ ! -f pyproject.toml ]; then
		echo "Skipping coverage: no pyproject.toml found."
		exit 0
	fi
	if ! rg --files tests -g 'test_*.py' -g '*_test.py' >/dev/null 2>&1; then
		echo "Skipping coverage: no pytest-style Python tests found."
		exit 0
	fi
	uvx --from coverage --with pytest --with-editable . coverage run -m pytest
	uvx --from coverage coverage xml --fail-under=100 -o coverage.xml

_diff-cover: _pytest_with_coverage
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: diff-cover against main branch ==="
	echo "# Reports coverage gaps on code changed since main branch to ensure new code is tested"
	if [ ! -f coverage.xml ]; then
		echo "Skipping diff-cover: no coverage.xml generated."
		exit 0
	fi
	uvx --from diff-cover diff-cover coverage.xml --compare-branch ${DIFF_COVER_BASE:-main}

_vulture: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: vulture dead code detection ==="
	echo "# Finds unused code (functions, classes, variables) that can be safely removed"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	whitelist_file="{{justfile_directory()}}/vulture_whitelist.py"
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping vulture: no Python or Sage files found."
		exit 0
	fi
	uvx --from vulture vulture \
		--config {{justfile_directory()}}/pyproject.toml \
		"${python_files[@]}" \
		"$whitelist_file"

_deptry: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: deptry dependency linting ==="
	echo "# Checks for unused/missing dependencies in pyproject.toml, detects transitive deps, and verifies type checking"
	if [ ! -f pyproject.toml ]; then
		echo "Skipping deptry: no pyproject.toml found."
		exit 0
	fi
	uvx --from deptry deptry .

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: semgrep security pattern scanning ==="
	echo "# Static analysis for code quality and fraud patterns (trivial functions, self-reinforcing comments, print/console statements)"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping semgrep: no Python or Sage files found."
		exit 0
	fi
	uvx --from semgrep semgrep scan \
		--config={{justfile_directory()}}/semgrep.yml \
		--config=p/ci \
		--scan-unknown-extensions \
		--autofix \
		"${python_files[@]}"

_ast-grep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: ast-grep code quality audit ==="
	echo "# Custom AST rules for fraud detection (boolean assignment, loops without asserts, numeric bounds, self-reinforcing prints)"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping ast-grep: no Python or Sage files found."
		exit 0
	fi
	findings_file=$(mktemp)
	trap 'rm -f "$findings_file"' EXIT
	npx -y ast-grep scan \
		--config {{justfile_directory()}}/sgconfig.yml \
		--report-style short \
		"${python_files[@]}" | tee "$findings_file"
	if [ -s "$findings_file" ]; then
		echo "Blocking just test: fraud-review warnings were found and must be reviewed against repository audit guidelines."
		exit 1
	fi

_jscpd:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: jscpd copy-paste detection ==="
	echo "# Finds duplicate code blocks across the codebase that may indicate copypaste or missing refactoring"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping jscpd: no Python or Sage files found."
		exit 0
	fi
	npx -y jscpd \
		--config {{justfile_directory()}}/.jscpd.json \
		--format python \
		--formats-exts python:py,sage \
		"${python_files[@]}"

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: lizard complexity analysis ==="
	echo "# Computes cyclomatic complexity number (CCN), line count, and parameter count to flag overly complex functions"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping lizard: no Python or Sage files found."
		exit 0
	fi
	uvx --from lizard lizard -l python -C 7 -L 100 -a 5 -i 0 "${python_files[@]}"

_import-linter: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: import-linter dependency rules ==="
	echo "# Enforces layer-based import rules (e.g., core cannot import from plugins, data cannot import from domain)"
	config=""
	if [ -f .importlinter ]; then
		config=".importlinter"
	elif [ -f pyproject.toml ] && python -c 'import pathlib, sys, tomllib; data = tomllib.loads(pathlib.Path("pyproject.toml").read_text(encoding="utf-8")); tool_section = data.get("tool", {}); sys.exit(0 if ("import-linter" in tool_section or "importlinter" in tool_section) else 1)'
	then
		config="pyproject.toml"
	fi
	if [ -z "$config" ]; then
		echo "Skipping import-linter: no project-specific import-linter config found."
		exit 0
	fi
	uvx --from import-linter --with-editable . lint-imports --config "$config"

_grain:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: grain unused code detection ==="
	echo "# Finds unused imports and variables that can be safely removed"
	cp {{justfile_directory()}}/grain.toml .grain.toml
	uvx --from git+https://github.com/mmartoccia/grain grain check --all --fix
	rm .grain.toml

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: codeql security analysis ==="
	echo "# GitHub's static analysis engine for code quality and security vulnerabilities"
	if ! command -v codeql >/dev/null 2>&1; then
		echo "Skipping CodeQL: codeql CLI is not installed."
		exit 0
	fi
	codeql database create codeql-db --overwrite --language=python --source-root=.
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif

_slop:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: ai-slop-detector ML-based quality check ==="
	echo "# ML classifier for detecting AI-generated code patterns and low-quality implementations"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping ai-slop-detector: no Python or Sage files found."
		exit 0
	fi
	for file in "${python_files[@]}"; do
		uvx ai-slop-detector "$file" \
			--config {{justfile_directory()}}/.slopconfig.yaml \
			--verbose \
			--ci-mode hard \
			--ci-claims-strict \
			--ci-report \
			--no-color
	done

# public: all static checks run locally
test: _no-bypass _normalize _vulture _deptry _semgrep _ast-grep _jscpd _lizard _import-linter _codeql _slop _grain _diff-cover _pytest_with_coverage
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Local quality checks completed"

