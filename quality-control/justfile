# justfile for Python quality control
#
# PURPOSE OF A JUSTFILE:
# 1) ENSHRINE WORKFLOWS: Every workflow lives in the justfile. No ad-hoc
#    scripts, no "I'll just run this command directly". Justfile is the
#    single source of truth for project operations.
# 2) FIX OPINIONATED WORKFLOWS: Agents cannot cherry-pick checks. For
#    example, `just typecheck` does NOT assert code quality — the `test`
#    recipe runs the full QC stack. Running only typecheck is insufficient.
# 3) ABSTRACT COMPLEXITY: Env management, sandbox setup, tool installation,
#    common tasks — all hidden in private recipes. Users run workflows,
#    not infrastructure.
#
# WORKFLOW:
#   just test      — local quality checks (linting, static analysis, complexity)
#   just test-ci  — test + live/isolated checks (coverage, diff-cover, integration tests)
#   Both are public. Everything else is private. Do NOT add public recipes.
#
# HOOKS: pre-commit.hook and pre-push.hook both block on `just test`.
#   Copy/symlink into .git/hooks/ to activate.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory. No symlinks needed. Configs read by each tool:
#   .slopconfig.yaml → ai-slop-detector (explicit --config flag)
#   semgrep.yml    → semgrep local rules (explicit --config flag)
#   .jscpd.json    → jscpd (explicit --config flag)
#   .coveragerc    → coverage.py reads .coveragerc from cwd (run from project root)
# GLOBAL CONFIGS OK: vulture, deptry, diff-cover, ruff, black, mypy
# all read from ~/.config/ or pyproject.toml [tool.*] sections.

default:
  @just test

# private recipes (prefix with _ — never run individually)
_no-bypass:
	#!/usr/bin/env bash
	set -euo pipefail
	# Block attempts to hide/launder QC issues via bypass comments
	files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
	[ -z "$files" ] && exit 0
	for file in $files; do
		[ -f "$file" ] || continue
		# Python coverage bypass
		if grep -n "# pragma: no cover" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# pragma: no cover' — fix coverage, don't hide it"
			exit 1
		fi
		# JS coverage bypass
		if grep -n "// istanbul ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// istanbul ignore' — fix coverage, don't hide it"
			exit 1
		fi
		# Python lint bypass
		if grep -n "# noqa" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# noqa' — fix lint errors, don't hide them"
			exit 1
		fi
		# Python type bypass
		if grep -n "# type: ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '# type: ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS bypass
		if grep -n "@ts-ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS expect-error without comment
		if grep -n "@ts-expect-error$" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-expect-error' without justification — add a comment explaining why"
			exit 1
		fi
		# ESLint bypass
		if grep -n "// eslint-disable" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// eslint-disable' — fix lint errors, don't hide them"
			exit 1
		fi
	done
	echo "No bypass comments detected in staged files"

_venv:
	#!/usr/bin/env bash
	set -euo pipefail
	uv venv --allow-existing

_install-tools: _venv
	#!/usr/bin/env bash
	set -euo pipefail
	uv pip install coverage diff-cover vulture deptry semgrep lizard import-linter

_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run coverage run -m pytest
	uv run coverage xml --fail-under=100 -o coverage.xml

_pytest_with_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: pytest with coverage measurement ==="
	echo "# Runs pytest with coverage.py to enforce 100% line/branch coverage and generate coverage.xml"
	if [ ! -f pyproject.toml ]; then
		echo "Skipping coverage: no pyproject.toml found."
		exit 0
	fi
	if ! rg --files tests -g 'test_*.py' -g '*_test.py' >/dev/null 2>&1; then
		echo "Skipping coverage: no pytest-style Python tests found."
		exit 0
	fi
	project_root="$(pwd -P)"
	project_slug="$(printf '%s' "$project_root" | sed 's#[^A-Za-z0-9._-]#_#g')"
	coverage_root="${XDG_CACHE_HOME:-$HOME/.cache}/quality-control/coverage/$project_slug"
	coverage_data="$coverage_root/.coverage"
	coverage_xml="$coverage_root/coverage.xml"
	mkdir -p "$coverage_root"
	COVERAGE_FILE="$coverage_data" uvx --from coverage --with pytest --with-editable . coverage run -m pytest
	COVERAGE_FILE="$coverage_data" uvx --from coverage coverage xml --fail-under=100 -o "$coverage_xml"
	echo "Coverage XML report: $coverage_xml"

_diff-cover: _pytest_with_coverage
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: diff-cover against main branch ==="
	echo "# Reports coverage gaps on code changed since main branch to ensure new code is tested"
	project_root="$(pwd -P)"
	project_slug="$(printf '%s' "$project_root" | sed 's#[^A-Za-z0-9._-]#_#g')"
	coverage_xml="${XDG_CACHE_HOME:-$HOME/.cache}/quality-control/coverage/$project_slug/coverage.xml"
	if [ ! -f "$coverage_xml" ]; then
		echo "Skipping diff-cover: no coverage.xml generated at $coverage_xml."
		exit 0
	fi
	uvx --from diff-cover diff-cover "$coverage_xml" --compare-branch ${DIFF_COVER_BASE:-main}

_vulture: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	args=(--min-confidence 60)
	if [ -f pyproject.toml ]; then
		args+=(--config pyproject.toml)
	fi
	paths=()
	for path in src tests; do
		if [ -e "$path" ]; then
			paths+=("$path")
		fi
	done
	if [ -f vulture_whitelist.py ]; then
		paths+=(vulture_whitelist.py)
	fi
	if [ "${#paths[@]}" -eq 0 ]; then
		echo "Skipping vulture: no src/tests paths found."
		exit 0
	fi
	uv run vulture "${args[@]}" "${paths[@]}"

_deptry: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run deptry .

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run semgrep --config={{justfile_directory()}}/semgrep.yml --config=p/ci

_jscpd:
	#!/usr/bin/env bash
	set -euo pipefail
	npx -y jscpd --config {{justfile_directory()}}/.jscpd.json

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uv run lizard src -l python -C 7 -L 100 -a 5 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*"

_import-linter: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	config=""
	if [ -f .importlinter ]; then
		config=".importlinter"
	elif [ -f pyproject.toml ] && python -c 'import pathlib, sys, tomllib; data = tomllib.loads(pathlib.Path("pyproject.toml").read_text(encoding="utf-8")); tool_section = data.get("tool", {}); sys.exit(0 if ("import-linter" in tool_section or "importlinter" in tool_section) else 1)'
	then
		config="pyproject.toml"
	fi
	if [ -z "$config" ]; then
		echo "Skipping import-linter: no project-specific import-linter config found."
		exit 0
	fi
	uv run lint-imports --config "$config"

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	if ! command -v codeql >/dev/null 2>&1; then
		echo "Skipping CodeQL: codeql CLI is not installed."
		exit 0
	fi
	project_root="$(pwd -P)"
	project_slug="$(printf '%s' "$project_root" | sed 's#[^A-Za-z0-9._-]#_#g')"
	codeql_root="${XDG_CACHE_HOME:-$HOME/.cache}/quality-control/codeql/$project_slug"
	db="$codeql_root/codeql-db"
	report="$codeql_root/codeql-report.sarif"
	mkdir -p "$codeql_root"
	codeql database create "$db" --overwrite --language=python --source-root="$project_root"
	codeql database analyze "$db" --format=sarif-latest --output="$report"
	echo "CodeQL SARIF report: $report"
	python3 - "$report" <<'PY'
	import json
	import sys
	from pathlib import Path

	report = Path(sys.argv[1])
	if not report.exists():
		print(f"CodeQL summary unavailable: report not found at {report}")
		raise SystemExit(0)

	data = json.loads(report.read_text())
	rule_levels = {}
	for run in data.get("runs", []):
		for rule in run.get("tool", {}).get("driver", {}).get("rules", []):
			level = rule.get("defaultConfiguration", {}).get("level")
			if level:
				rule_levels[rule.get("id")] = level

	findings = []
	for run in data.get("runs", []):
		for result in run.get("results", []):
			rule_id = result.get("ruleId", "unknown-rule")
			level = result.get("level") or rule_levels.get(rule_id, "note")
			message = result.get("message", {}).get("text", "").replace("\n", " ").strip()
			location = result.get("locations", [{}])[0].get("physicalLocation", {})
			artifact = location.get("artifactLocation", {})
			uri = artifact.get("uri", "unknown-file")
			region = location.get("region", {})
			line = region.get("startLine")
			file_ref = f"{uri}:{line}" if line else uri
			findings.append((level, rule_id, file_ref, message))

	print(f"CodeQL findings: {len(findings)}")
	for level, rule_id, file_ref, message in findings[:50]:
		print(f"- [{level}] {rule_id} {file_ref}: {message}")
	if len(findings) > 50:
		print(f"- ... {len(findings) - 50} more findings omitted; see SARIF report above.")
	PY

_slop:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: ai-slop-detector ML-based quality check ==="
	echo "# ML classifier for detecting AI-generated code patterns and low-quality implementations"
	project_root="$(pwd -P)"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping ai-slop-detector: no Python or Sage files found."
		exit 0
	fi
	for file in "${python_files[@]}"; do
		target="$file"
		if [[ "$target" != /* ]]; then
			target="$project_root/$target"
		fi
		(
			cd {{justfile_directory()}}
			uvx ai-slop-detector "$target" \
			--config {{justfile_directory()}}/.slopconfig.yaml \
			--verbose \
			--ci-mode hard \
			--ci-claims-strict \
			--ci-report \
			--no-color
		)
	done

