_slop-scan:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: slop-scan JS/TS anti-pattern detection ==="
	echo "# Scans JS/TS files for AI-associated slop patterns (error-swallowing, duplicate signatures, generic casts, etc.)"
	mapfile -t js_files < <(just --justfile {{justfile()}} -d . _js-qc-files)
	if [ "${#js_files[@]}" -eq 0 ]; then
		echo "Skipping slop-scan: no JS/TS files found."
		exit 0
	fi
	npx -y slop-scan scan --lint .

_slop:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: ai-slop-detector ML-based quality check ==="
	echo "# ML classifier for detecting AI-generated code patterns and low-quality implementations"
	project_root="$(pwd -P)"
	mapfile -t python_files < <(just --justfile {{justfile()}} -d . _python-qc-files)
	if [ "${#python_files[@]}" -eq 0 ]; then
		echo "Skipping ai-slop-detector: no Python or Sage files found."
		exit 0
	fi
	for file in "${python_files[@]}"; do
		target="$file"
		if [[ "$target" != /* ]]; then
			target="$project_root/$target"
		fi
		(
			cd {{justfile_directory()}}
			uvx ai-slop-detector "$target" \
			--config {{justfile_directory()}}/.slopconfig.yaml \
			--verbose \
			--ci-mode hard \
			--ci-claims-strict \
			--ci-report \
			--no-color
		)
	done

# public: all static checks run locally
test: _python-syntax _sage-syntax _mypy _normalize _no-bypass _deptry _import-linter _semgrep _ast-grep _jscpd _lizard _vulture _grain _codeql _pytest_with_coverage _diff-cover _slop _slop-scan
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Local quality checks completed"

