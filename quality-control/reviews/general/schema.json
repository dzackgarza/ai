{
  "finding_required_fields": [
    "tier",
    "label",
    "category",
    "location",
    "symptom",
    "source",
    "consequence",
    "evidence"
  ],
  "report_required_markers": ["Finding\\s+\\d+", "Symptom:", "Source:", "Consequence:"],
  "forbidden_categories": ["infra", "infrastructure", "ci", "workflow", "config"],
  "report_min_length": 200,
  "report_reject_patterns": [
    "-O",
    "optimized mode",
    "passed without",
    "no violations",
    "clean code",
    "all.*(other|remaining).*(passed|clean|fine|acceptable)",
    "no.*(bridge.burning|runtime.control.flow).*violation",
    "nothing (to |)report",
    "full repository sweep",
    "full.*sweep.*(excluding|excluded)",
    "excluding forbidden",
    "excluded targets"
  ]
}
