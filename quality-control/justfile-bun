# justfile-bun — TypeScript quality control with bun
#
# PURPOSE OF A JUSTFILE:
# 1) ENSHRINE WORKFLOWS: Every workflow lives in the justfile. No ad-hoc
#    scripts, no "I'll just run this command directly". Justfile is the
#    single source of truth for project operations.
# 2) FIX OPINIONATED WORKFLOWS: Agents cannot cherry-pick checks. For
#    example, `just typecheck` does NOT assert code quality — the `test`
#    recipe runs the full QC stack. Running only typecheck is insufficient.
# 3) ABSTRACT COMPLEXITY: Env management, sandbox setup, tool installation,
#    common tasks — all hidden in private recipes. Users run workflows,
#    not infrastructure.
#
# WORKFLOW:
#   just test      — local quality checks (linting, static analysis, complexity)
#   just test-ci  — test + live/isolated checks (coverage, diff-cover, integration tests)
#   Both are public. Everything else is private. Do NOT add public recipes.
#
# HOOKS: pre-commit.hook and pre-push.hook both block on `just test`.
#   Copy/symlink into .git/hooks/ to activate.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory. No symlinks needed. Configs read by each tool:
#   knip.json         → knip (explicit --config flag)
#   semgrep.yml       → semgrep local rules (explicit --config flag)
#   .jscpd.json       → jscpd (explicit --config flag)
#   biome.json        → biome (explicit --config flag)
#   eslint.config.js  → eslint (explicit --config flag)
#   sgconfig.yml      → ast-grep (auto-discovered)
#   .lintstagedrc.json → lint-staged (explicit --config flag)
# GLOBAL CONFIGS OK: prettier (project .prettierrc),
# lizard (CLI flags only).

default:
  @just test

# private recipes (prefix with _ — never run individually)
_no-bypass:
	#!/usr/bin/env bash
	set -euo pipefail
	# Block attempts to hide/launder QC issues via bypass comments
	# Check both staged and unstaged modified files
	staged=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
	unstaged=$(git ls-files --modified 2>/dev/null || echo "")
	files=$(printf "%s\n%s" "$staged" "$unstaged" | sort -u | sed '/^$/d')
	[ -z "$files" ] && exit 0
	for file in $files; do
		[ -f "$file" ] || continue
		# Type safety bypass: double-cast (as T as U)
		if grep -nP 'as\s+(unknown|any|never)\s+as\s' "$file" 2>/dev/null; then
			echo "ERROR: $file contains a double-cast bypass (e.g., 'as unknown as') — use a proper type assertion or restructure the code"
			exit 1
		fi
		# JS coverage bypass
		if grep -n "// istanbul ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// istanbul ignore' — fix coverage, don't hide it"
			exit 1
		fi
		# TS bypass
		if grep -n "@ts-ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS expect-error without comment
		if grep -n "@ts-expect-error$" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-expect-error' without justification — add a comment explaining why"
			exit 1
		fi
		# ESLint bypass
		if grep -n "// eslint-disable" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// eslint-disable' — fix lint errors, don't hide them"
			exit 1
		fi
	done
	echo "No bypass comments detected in staged files"

_install-tools:
	#!/usr/bin/env bash
	set -euo pipefail
	# ESLint plugins must be installed LOCAL to the quality-control directory.
	# ESLint flat config uses ES module imports that resolve relative to the
	# config file's location — NODE_PATH is ignored for ESM. Global installs
	# are invisible to the config loader.
	cd {{justfile_directory()}}
	bun install --frozen-lockfile
	# Other tools run as standalone binaries and don't need config-local resolution.
	for tool in knip jscpd biome ast-grep lint-staged; do
		command -v "$tool" >/dev/null 2>&1 && continue
		case "$tool" in
			biome) bun add --global @biomejs/biome ;;
			ast-grep) bun add --global @ast-grep/cli ;;
			*) bun add --global "$tool" ;;
		esac
	done

_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	if jq -e '.scripts.test // empty' package.json >/dev/null 2>&1; then
		bun run test
		exit 0
	fi
	if [ ! -d tests ] && [ ! -d __tests__ ]; then
		echo "ERROR: no test script and no tests directory found — 0% coverage"
		exit 1
	fi
	bun test --coverage --coverage-reporter=lcov --coverage-dir=.

_diff-cover: _coverage
	#!/usr/bin/env bash
	set -euo pipefail
	if [ ! -f lcov.info ]; then
		echo "Skipping diff-cover: lcov.info not produced (no tests matched by bun test)."
		exit 0
	fi
	bun x diff-cover lcov.info --compare-branch ${DIFF_COVER_BASE:-main}

_knip: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x knip --config {{justfile_directory()}}/knip.json --no-config-hints

_biome: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	dirs=()
	[ -d src ] && dirs+=(src)
	[ -d tests ] && dirs+=(tests)
	[ ${#dirs[@]} -eq 0 ] && dirs=(.)
	bun x biome check --config-path {{justfile_directory()}}/biome.json "${dirs[@]}"

_ast-grep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x ast-grep scan --config {{justfile_directory()}}/sgconfig.yml

_eslint: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	# Invoke via absolute path to quality-control's local eslint binary.
	# This keeps CWD = project dir (so files/**/*.ts matches project files)
	# while Node.js resolves the flat config's ES module imports from the
	# config file's directory (/home/dzack/ai/quality-control/node_modules/).
	"{{justfile_directory()}}/node_modules/.bin/eslint" \
		--config {{justfile_directory()}}/eslint.config.js \
		. --max-warnings 0

_tsc:
	#!/usr/bin/env bash
	set -euo pipefail
	if jq -e '.scripts.types // empty' package.json >/dev/null 2>&1; then
		bun run types
	elif command -v ags >/dev/null 2>&1 \
		&& [ -f tsconfig.json ] \
		&& jq -e '.compilerOptions.jsxImportSource == "ags/gtk4" or ((.compilerOptions.paths // {}) | has("gi://Astal?version=4.0"))' tsconfig.json >/dev/null 2>&1; then
		ags types 'Astal*' --ignore Gtk3 --ignore Astal3 --update
	fi
	if jq -e '.scripts.typecheck // empty' package.json >/dev/null 2>&1; then
		output="$(mktemp)"
		if ! bun run typecheck >"$output" 2>&1; then
			if grep -vE '/usr/share/ags/js/|\.\./.*usr/share/ags/js/|gi://' "$output" | grep -q 'error TS'; then
				cat "$output"
				rm -f "$output"
				exit 1
			fi
			cat "$output"
			rm -f "$output"
			echo "Only system AGS/Gnim TypeScript diagnostics were reported; project-owned TypeScript passed."
			exit 0
		fi
		cat "$output"
		rm -f "$output"
	elif [ -f tsconfig.json ]; then
		output="$(mktemp)"
		if [ -x node_modules/.bin/tsc ]; then
			tsc_cmd=(node_modules/.bin/tsc --noEmit --skipLibCheck -p tsconfig.json)
		else
			tsc_cmd=(tsc --noEmit --skipLibCheck -p tsconfig.json)
		fi
		if "${tsc_cmd[@]}" >"$output" 2>&1; then
			cat "$output"
			rm -f "$output"
			exit 0
		fi
		cat "$output"
		if grep -vE '/usr/share/ags/js/|\.\./.*usr/share/ags/js/|gi://' "$output" | grep -q 'error TS'; then
			rm -f "$output"
			exit 1
		fi
		rm -f "$output"
		echo "Only system AGS/Gnim TypeScript diagnostics were reported; project-owned TypeScript passed."
	else
		echo "ERROR: no package typecheck script and no tsconfig.json found"
		exit 1
	fi

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uvx semgrep --config {{justfile_directory()}}/semgrep.yml --config=p/ci --exclude=codeql-db

_jscpd: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x jscpd --config {{justfile_directory()}}/.jscpd.json

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uvx lizard . -l typescript -C 8 -L 200 -a 7 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*" \
		-x "*/_ci-support/*" \
		-x "*/@girs/*"

_vibecheck:
	#!/usr/bin/env bash
	set -euo pipefail
	uvx --from git+https://github.com/qinnovates/vibecheck-slop-stopper vibecheck . --severity high

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	if ! command -v codeql >/dev/null 2>&1; then
		echo "Skipping CodeQL: codeql CLI is not installed."
		exit 0
	fi
	codeql database create codeql-db --overwrite --language=typescript --source-root=. --search-path=/dev/null 2>&1 | grep -v "Extracting\|Done extracting\|already exists" || true
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif || true
	rm -rf codeql-db codeql-report.sarif

_lint-staged: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x lint-staged --config {{justfile_directory()}}/.lintstagedrc.json

_normalize: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: biome format, lint, and import sorting (auto-fix) ==="
	echo "# Auto-applies safe and unsafe fixes, formatting, and import sorting"
	dirs=()
	[ -d src ] && dirs+=(src)
	[ -d tests ] && dirs+=(tests)
	[ ${#dirs[@]} -eq 0 ] && dirs=(.)
	bun x biome check --write --unsafe --config-path {{justfile_directory()}}/biome.json "${dirs[@]}"
	echo "=== Running: eslint auto-fix ==="
	"{{justfile_directory()}}/node_modules/.bin/eslint" \
		--config {{justfile_directory()}}/eslint.config.js \
		--fix \
		. 2>&1 || true
	echo "=== Running: semgrep auto-fix ==="
	uvx semgrep --config {{justfile_directory()}}/semgrep.yml --config=p/ci \
		--autofix \
		--exclude=codeql-db 2>&1 || true

# public: all static checks run locally
test: _normalize _no-bypass _coverage _diff-cover _knip _biome _ast-grep _eslint _tsc _semgrep _jscpd _lizard _vibecheck
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Local quality checks completed"

# public: test-ci = test + live/isolated checks
# Add project-specific live tests (needs docker, live server, etc.) here
test-ci: test
	#!/usr/bin/env bash
	set -euo pipefail
	echo "CI checks completed"
