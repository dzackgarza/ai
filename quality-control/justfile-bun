# justfile-bun — TypeScript quality control with bun
#
# WORKFLOW: Always run `just test`. Do NOT add public recipes for
# additional checks. The `test` recipe depends on the full quality
# control stack — bypassing it defeats the purpose of enforced gates.
# Add new analyses as private recipes (prefix with _) and add them to
# the `test` dependency list.

default:
  @just test

# private recipes (prefix with _ — do not run individually in CI)
_install-tools:
	#!/usr/bin/env bash
	set -euo pipefail
	bun add -d @bun/test c8 knip eslint typescript semgrep jscpd lizard-py

_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun test --coverage --coverage-reporter=cobertura --coverage-dir=.
	bun x c8 report --reporter=cobertura --report-dir=.

_diff-cover: _coverage
	#!/usr/bin/env bash
	set -euo pipefail
	bun x diff-cover coverage.cobertura.xml --compare-branch ${DIFF_COVER_BASE:-main}

_knip: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x knip --config knip.json

_eslint: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x eslint . --max-warnings 0

_tsc: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x tsc --noEmit

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x semgrep --config semgrep.yml --config=p/ci --inline-suppression

_jscpd: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x jscpd --config .jscpd.json

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x lizard src -l typescript -C 7 -L 100 -a 5 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*"

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	codeql database create codeql-db --language=typescript --source-root=.
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif

# top-level test depends on all private analyses
test: _coverage _diff-cover _knip _eslint _tsc _semgrep _jscpd _lizard _codeql
	#!/usr/bin/env bash
	set -euo pipefail
	echo "All analyses completed"
