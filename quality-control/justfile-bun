# justfile-bun — TypeScript quality control with bun
#
# PURPOSE OF A JUSTFILE:
# 1) ENSHRINE WORKFLOWS: Every workflow lives in the justfile. No ad-hoc
#    scripts, no "I'll just run this command directly". Justfile is the
#    single source of truth for project operations.
# 2) FIX OPINIONATED WORKFLOWS: Agents cannot cherry-pick checks. For
#    example, `just typecheck` does NOT assert code quality — the `test`
#    recipe runs the full QC stack (coverage, complexity, dead code,
#    duplication, etc). Running only typecheck is insufficient.
# 3) ABSTRACT COMPLEXITY: Env management, sandbox setup, tool installation,
#    common tasks — all hidden in private recipes. Users run workflows,
#    not infrastructure.
#
# MINIMAL QUALITY CONTROL: This justfile encodes the minimal QC stack
# that MUST be present in every TypeScript project. The `test` recipe
# is the single entry point — run `just test` always. Do NOT bypass it.
#
# NARROW PUBLIC SURFACE: Only expose essential public recipes. Encode
# all standard project workflows (build, dev, deploy, etc.) in justfile
# recipes — but these are private or grouped separately. The `test`
# recipe's dependency graph is the only thing that gates CI.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory. No symlinks needed. Configs read by each tool:
#   knip.json         → knip (explicit --config flag)
#   semgrep.yml       → semgrep local rules (explicit --config flag)
#   .jscpd.json       → jscpd (explicit --config flag)
#   biome.json        → biome (explicit --config flag)
#   sgconfig.yml      → ast-grep (auto-discovered)
#   .lintstagedrc.json → lint-staged (explicit --config flag)
# HOOKS: pre-commit.hook, pre-push.hook — symlink into .git/hooks/
# GLOBAL CONFIGS OK: eslint, prettier (project .eslintrc/.prettierrc),
# c8 (package.json [c8] or .c8rc), lizard (CLI flags only).

default:
  @just test

# private recipes (prefix with _ — do not run individually in CI)
_install-tools:
	#!/usr/bin/env bash
	set -euo pipefail
	bun add -d @bun/test c8 knip eslint typescript semgrep jscpd lizard-py @biomejs/biome @ast-grep/cli lint-staged

_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun test --coverage --coverage-reporter=cobertura --coverage-dir=.
	bun x c8 report --reporter=cobertura --report-dir=.

_diff-cover: _coverage
	#!/usr/bin/env bash
	set -euo pipefail
	bun x diff-cover coverage.cobertura.xml --compare-branch ${DIFF_COVER_BASE:-main}

_knip: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x knip --config {{justfile_directory()}}/knip.json

_eslint: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x eslint . --max-warnings 0

_tsc: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x tsc --noEmit

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x semgrep --config {{justfile_directory()}}/semgrep.yml --config=p/ci --inline-suppression

_jscpd: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x jscpd --config {{justfile_directory()}}/.jscpd.json

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x lizard src -l typescript -C 7 -L 100 -a 5 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*"

_biome: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x biome check --config {{justfile_directory()}}/biome.json .

_ast-grep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x ast-grep scan --config {{justfile_directory()}}/sgconfig.yml

_lint-staged: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x lint-staged --config {{justfile_directory()}}/.lintstagedrc.json

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	codeql database create codeql-db --language=typescript --source-root=.
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif

# top-level test depends on all private analyses
test: _coverage _diff-cover _knip _biome _ast-grep _eslint _tsc _semgrep _jscpd _lizard _codeql
	#!/usr/bin/env bash
	set -euo pipefail
	echo "All analyses completed"
