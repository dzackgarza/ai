# justfile-bun — TypeScript quality control with bun
#
# PURPOSE OF A JUSTFILE:
# 1) ENSHRINE WORKFLOWS: Every workflow lives in the justfile. No ad-hoc
#    scripts, no "I'll just run this command directly". Justfile is the
#    single source of truth for project operations.
# 2) FIX OPINIONATED WORKFLOWS: Agents cannot cherry-pick checks. For
#    example, `just typecheck` does NOT assert code quality — the `test`
#    recipe runs the full QC stack. Running only typecheck is insufficient.
# 3) ABSTRACT COMPLEXITY: Env management, sandbox setup, tool installation,
#    common tasks — all hidden in private recipes. Users run workflows,
#    not infrastructure.
#
# WORKFLOW:
#   just test      — local quality checks (linting, static analysis, complexity)
#   just test-ci  — test + live/isolated checks (coverage, diff-cover, integration tests)
#   Both are public. Everything else is private. Do NOT add public recipes.
#
# HOOKS: pre-commit.hook and pre-push.hook both block on `just test`.
#   Copy/symlink into .git/hooks/ to activate.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory. No symlinks needed. Configs read by each tool:
#   knip.json         → knip (explicit --config flag)
#   semgrep.yml       → semgrep local rules (explicit --config flag)
#   .jscpd.json       → jscpd (explicit --config flag)
#   biome.json        → biome (explicit --config flag)
#   eslint.config.js  → eslint (explicit --config flag)
#   sgconfig.yml      → ast-grep (auto-discovered)
#   .lintstagedrc.json → lint-staged (explicit --config flag)
# GLOBAL CONFIGS OK: prettier (project .prettierrc),
# c8 (package.json [c8] or .c8rc), lizard (CLI flags only).

default:
  @just test

# private recipes (prefix with _ — never run individually)
_no-bypass:
	#!/usr/bin/env bash
	set -euo pipefail
	# Block attempts to hide/launder QC issues via bypass comments
	files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
	[ -z "$files" ] && exit 0
	for file in $files; do
		[ -f "$file" ] || continue
		# JS coverage bypass
		if grep -n "// istanbul ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// istanbul ignore' — fix coverage, don't hide it"
			exit 1
		fi
		# TS bypass
		if grep -n "@ts-ignore" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-ignore' — fix type errors, don't hide them"
			exit 1
		fi
		# TS expect-error without comment
		if grep -n "@ts-expect-error$" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '@ts-expect-error' without justification — add a comment explaining why"
			exit 1
		fi
		# ESLint bypass
		if grep -n "// eslint-disable" "$file" 2>/dev/null; then
			echo "ERROR: $file contains '// eslint-disable' — fix lint errors, don't hide them"
			exit 1
		fi
	done
	echo "No bypass comments detected in staged files"

_install-tools:
	#!/usr/bin/env bash
	set -euo pipefail
	bun add --global \
		c8 \
		knip \
		eslint \
		typescript \
		jscpd \
		@biomejs/biome \
		@ast-grep/cli \
		lint-staged \
		@typescript-eslint/parser \
		@typescript-eslint/eslint-plugin \
		eslint-plugin-promise \
		eslint-plugin-fp \
		@lwc/eslint-plugin-lwc

_coverage: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun test --coverage --coverage-reporter=cobertura --coverage-dir=.
	bun x c8 report --reporter=cobertura --report-dir=.
	bun x c8 check-coverage --100

_diff-cover: _coverage
	#!/usr/bin/env bash
	set -euo pipefail
	bun x diff-cover coverage.cobertura.xml --compare-branch ${DIFF_COVER_BASE:-main}

_knip: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x knip --config {{justfile_directory()}}/knip.json

_biome: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	dirs=()
	[ -d src ] && dirs+=(src)
	[ -d tests ] && dirs+=(tests)
	[ ${#dirs[@]} -eq 0 ] && dirs=(.)
	bun x biome check --config-path {{justfile_directory()}}/biome.json "${dirs[@]}"

_ast-grep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x ast-grep scan --config {{justfile_directory()}}/sgconfig.yml

_eslint: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x eslint --config {{justfile_directory()}}/eslint.config.js . --max-warnings 0

_tsc: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x tsc --noEmit

_semgrep: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uvx semgrep --config {{justfile_directory()}}/semgrep.yml --config=p/ci

_jscpd: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x jscpd --config {{justfile_directory()}}/.jscpd.json

_lizard: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	uvx lizard . -l typescript -C 8 -L 100 -a 5 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*"

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	codeql database create codeql-db --overwrite --language=typescript --source-root=.
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif

_lint-staged: _install-tools
	#!/usr/bin/env bash
	set -euo pipefail
	bun x lint-staged --config {{justfile_directory()}}/.lintstagedrc.json

# public: all static checks run locally
test: _no-bypass _coverage _diff-cover _knip _biome _ast-grep _eslint _tsc _semgrep _jscpd _lizard _codeql
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Local quality checks completed"

# public: test-ci = test + live/isolated checks
# Add project-specific live tests (needs docker, live server, etc.) here
test-ci: test
	#!/usr/bin/env bash
	set -euo pipefail
	echo "CI checks completed"
