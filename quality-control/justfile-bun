# justfile-bun — TypeScript-specific quality control
#
# Imports cross-language QC recipes from `justfile` (shared) and adds
# TypeScript-specific recipes. TypeScript projects delegate to this file:
#   just -f ~/ai/quality-control/justfile-bun test
#
# Shared recipes (imported from justfile):
#   _no-bypass, _semgrep, _vibecheck, _slop
#
# TypeScript-specific recipes:
#   _coverage, _diff-cover, _knip, _biome, _eslint, _tsc,
#   _normalize (biome + eslint), _ast-grep, _jscpd, _lizard,
#   _codeql, _slop-scan, _lint-staged
#
# WORKFLOW:
#   just test      — local quality checks (linting, static analysis, complexity)
#   just test-ci  — test + live/isolated checks (coverage, diff-cover, integration tests)
#
# HOOKS: pre-commit.hook and pre-push.hook both block on `just test`.
#   Copy/symlink into .git/hooks/ to activate.
#
# CONFIG: This justfile uses justfile_directory() to reference configs
# in this directory.

import 'justfile'

# private recipes (prefix with _ — never run individually)
_eslint-deps:
	#!/usr/bin/env bash
	set -euo pipefail
	# ESLint plugins must be installed LOCAL to the quality-control directory.
	# ESLint flat config uses ES module imports that resolve relative to the
	# config file's location — NODE_PATH is ignored for ESM. Global installs
	# are invisible to the config loader.
	# All other tools run ephemerally via bun x (see tool-provisioning-and-environment-hygiene).
	cd {{justfile_directory()}}
	bun install --frozen-lockfile

_coverage:
	#!/usr/bin/env bash
	set -euo pipefail
	if jq -e '.scripts.test // empty' package.json >/dev/null 2>&1; then
		bun run test
		exit 0
	fi
	if [ ! -d tests ] && [ ! -d __tests__ ]; then
		echo "ERROR: no test script and no tests directory found — 0% coverage"
		exit 1
	fi
	bun test --coverage --coverage-reporter=lcov --coverage-dir=.

_diff-cover: _coverage
	#!/usr/bin/env bash
	set -euo pipefail
	if [ ! -f lcov.info ]; then
		echo "ERROR: diff-cover: lcov.info not produced — coverage step did not produce output."
		exit 1
	fi
	bun x diff-cover lcov.info --compare-branch ${DIFF_COVER_BASE:-main}

_knip:
	#!/usr/bin/env bash
	set -euo pipefail
	bun x knip --config {{justfile_directory()}}/knip.json --no-config-hints

_biome:
	#!/usr/bin/env bash
	set -euo pipefail
	dirs=()
	[ -d src ] && dirs+=(src)
	[ -d tests ] && dirs+=(tests)
	[ ${#dirs[@]} -eq 0 ] && dirs=(.)
	bun x biome check --config-path {{justfile_directory()}}/biome.json "${dirs[@]}"

_ast-grep:
	#!/usr/bin/env bash
	set -euo pipefail
	bun x ast-grep scan --config {{justfile_directory()}}/sgconfig.yml

_eslint: _eslint-deps
	#!/usr/bin/env bash
	set -euo pipefail
	# Invoke via absolute path to quality-control's local eslint binary.
	# This keeps CWD = project dir (so files/**/*.ts matches project files)
	# while Node.js resolves the flat config's ES module imports from the
	# config file's directory (/home/dzack/ai/quality-control/node_modules/).
	"{{justfile_directory()}}/node_modules/.bin/eslint" \
		--config {{justfile_directory()}}/eslint.config.js \
		. --max-warnings 0

_tsc:
	#!/usr/bin/env bash
	set -euo pipefail
	if jq -e '.scripts.types // empty' package.json >/dev/null 2>&1; then
		bun run types
	elif command -v ags >/dev/null 2>&1 \
		&& [ -f tsconfig.json ] \
		&& jq -e '.compilerOptions.jsxImportSource == "ags/gtk4" or ((.compilerOptions.paths // {}) | has("gi://Astal?version=4.0"))' tsconfig.json >/dev/null 2>&1; then
		ags types 'Astal*' --ignore Gtk3 --ignore Astal3 --update
	fi
	if jq -e '.scripts.typecheck // empty' package.json >/dev/null 2>&1; then
		output="$(mktemp)"
		if ! bun run typecheck >"$output" 2>&1; then
			if grep -vE '/usr/share/ags/js/|\.\./.*usr/share/ags/js/|gi://' "$output" | grep -q 'error TS'; then
				cat "$output"
				rm -f "$output"
				exit 1
			fi
			cat "$output"
			rm -f "$output"
			echo "Only system AGS/Gnim TypeScript diagnostics were reported; project-owned TypeScript passed."
			exit 0
		fi
		cat "$output"
		rm -f "$output"
	elif [ -f tsconfig.json ]; then
		output="$(mktemp)"
		if [ -x node_modules/.bin/tsc ]; then
			tsc_cmd=(node_modules/.bin/tsc --noEmit --skipLibCheck -p tsconfig.json)
		else
			tsc_cmd=(tsc --noEmit --skipLibCheck -p tsconfig.json)
		fi
		if "${tsc_cmd[@]}" >"$output" 2>&1; then
			cat "$output"
			rm -f "$output"
			exit 0
		fi
		cat "$output"
		if grep -vE '/usr/share/ags/js/|\.\./.*usr/share/ags/js/|gi://' "$output" | grep -q 'error TS'; then
			rm -f "$output"
			exit 1
		fi
		rm -f "$output"
		echo "Only system AGS/Gnim TypeScript diagnostics were reported; project-owned TypeScript passed."
	else
		echo "ERROR: no package typecheck script and no tsconfig.json found"
		exit 1
	fi

_jscpd:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: jscpd copy-paste detection ==="
	echo "# Finds duplicate code blocks across JS/TS files"
	mapfile -t js_files < <(just --justfile {{justfile()}} -d . _js-qc-files)
	if [ "${#js_files[@]}" -eq 0 ]; then
		echo "ERROR: jscpd: no JS/TS files found."
		exit 1
	fi
	npx -y jscpd --config {{justfile_directory()}}/.jscpd.json \
		--format typescript \
		"${js_files[@]}"

_lizard:
	#!/usr/bin/env bash
	set -euo pipefail
	uvx lizard . -l typescript -C 8 -L 200 -a 7 -i 0 \
		-x "*/node_modules/*" \
		-x "*/__pycache__/*" \
		-x "*/.venv/*" \
		-x "*/dist/*" \
		-x "*/build/*" \
		-x "*/_ci-support/*" \
		-x "*/@girs/*"

_js-qc-files:
	#!/usr/bin/env bash
	set -euo pipefail
	rg --files \
		-g '*.ts' \
		-g '*.tsx' \
		-g '*.js' \
		-g '*.jsx' \
		-g '*.mjs' \
		-g '*.cjs' \
		-g '!**/node_modules/**' \
		-g '!**/dist/**' \
		-g '!**/build/**' \
		-g '!**/coverage/**'

_slop-scan:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: slop-scan JS/TS anti-pattern detection ==="
	echo "# Scans JS/TS files for AI-associated slop patterns (error-swallowing, duplicate signatures, generic casts, etc.)"
	mapfile -t js_files < <(just --justfile {{justfile()}} -d . _js-qc-files)
	if [ "${#js_files[@]}" -eq 0 ]; then
		echo "ERROR: slop-scan: no JS/TS files found in a TypeScript project."
		exit 1
	fi
	npx -y slop-scan scan --lint .

_codeql:
	#!/usr/bin/env bash
	set -euo pipefail
	if ! command -v codeql >/dev/null 2>&1; then
		echo "ERROR: CodeQL: codeql CLI is not installed. Install CodeQL from https://github.com/github/codeql-cli."
		exit 1
	fi
	codeql database create codeql-db --overwrite --language=typescript --source-root=. --search-path=/dev/null 2>&1 | grep -v "Extracting\|Done extracting\|already exists" || true
	codeql database analyze codeql-db --format=sarif-latest --output=codeql-report.sarif || true
	rm -rf codeql-db codeql-report.sarif

_lint-staged:
	#!/usr/bin/env bash
	set -euo pipefail
	bun x lint-staged --config {{justfile_directory()}}/.lintstagedrc.json

_check-ts-project:
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: TypeScript project preflight check ==="
	echo "# Validates project structure, Bun alignment, test presence, and QC config isolation"
	failed=0
	# 1. package.json must exist
	if [ ! -f "package.json" ]; then
		echo "ERROR: TypeScript project must have a package.json file."
		failed=1
	fi
	# 2. Must use Bun
	if [ ! -f "bun.lock" ] && [ ! -f "bun.lockb" ]; then
		echo "ERROR: TypeScript project must use Bun — no bun.lock or bun.lockb found."
		failed=1
	fi
	# 3. Check for local QC tool config overrides.
	#    Global QC owns these tool configs — projects must not set them locally.
	for config in biome.json eslint.config.js knip.json .lintstagedrc.json; do
		if [ -f "$config" ]; then
			echo "ERROR: Local QC override detected: $config — global QC owns this tool config."
			echo "       Remove it and use the global config in ~/ai/quality-control/ instead."
			failed=1
		fi
	done
	# 4. tsconfig.json must not disable strict mode
	if [ -f "tsconfig.json" ]; then
		if grep -qP '"strict"\s*:\s*false' tsconfig.json 2>/dev/null; then
			echo "ERROR: tsconfig.json has 'strict: false' — TypeScript strict mode is required by global QC."
			failed=1
		fi
	fi
	# 5. Tests must exist
	if ! rg --files -g '*.test.ts' -g '*.test.tsx' -g '*.spec.ts' -g '*.spec.tsx' -g 'tests/' >/dev/null 2>&1; then
		echo "ERROR: TypeScript project must have tests. No test files found with patterns: *.test.ts, *.test.tsx, *.spec.ts, *.spec.tsx, tests/"
		failed=1
	fi
	if [ "$failed" -ne 0 ]; then
		exit 1
	fi
	echo "TypeScript project configuration OK"

_normalize: _eslint-deps
	#!/usr/bin/env bash
	set -euo pipefail
	echo "============================="
	echo "=== Running: biome format, lint, and import sorting (auto-fix) ==="
	echo "# Auto-applies safe and unsafe fixes, formatting, and import sorting"
	dirs=()
	[ -d src ] && dirs+=(src)
	[ -d tests ] && dirs+=(tests)
	[ ${#dirs[@]} -eq 0 ] && dirs=(.)
	bun x biome check --write --unsafe --config-path {{justfile_directory()}}/biome.json "${dirs[@]}"
	echo "=== Running: eslint auto-fix ==="
	"{{justfile_directory()}}/node_modules/.bin/eslint" \
		--config {{justfile_directory()}}/eslint.config.js \
		--fix \
		. 2>&1 || true
	echo "=== Running: semgrep auto-fix ==="
	uvx semgrep --config {{justfile_directory()}}/semgrep.yml --config=p/ci \
		--autofix \
		--exclude=codeql-db 2>&1 || true

# public: all static checks run locally
test: _check-ts-project _check-no-local-qc-override _normalize _no-bypass _coverage _diff-cover _knip _biome _ast-grep _eslint _tsc _semgrep _jscpd _lizard _slop-scan _vibecheck _slop
	#!/usr/bin/env bash
	set -euo pipefail
	echo "Local quality checks completed"

# public: test-ci = test + live/isolated checks
# Add project-specific live tests (needs docker, live server, etc.) here
test-ci: test
	#!/usr/bin/env bash
	set -euo pipefail
	echo "CI checks completed"
