# Home directory justfile - personal automation
# Usage: just --justfile ~/ai/home-justfile <recipe>

repo := env_var_or_default("REPO", env_var("HOME") / "ai")

# Show available recipes
# Usage: just
default:
    @just --list

# Clean local caches and removable desktop debris.
clean:
    #!/usr/bin/env bash
    set -euo pipefail

    df -h
    trash-empty

    just --justfile "{{ justfile() }}" _opencode-clear-cache
    bash "{{ repo }}/opencode/scripts/maintenance/opencode_gc.sh"

    # Do not remove live session sockets. tmux uses /tmp/tmux-UID; mosh uses
    # /tmp/mosh-* on some installs; X/session buses also keep sockets here.
    sudo find /tmp -mindepth 1 -maxdepth 1 \
      ! -name 'tmux-*' \
      ! -name 'mosh-*' \
      ! -name '.X11-unix' \
      ! -name '.ICE-unix' \
      ! -name '.XIM-unix' \
      ! -name '.font-unix' \
      ! -name '.Test-unix' \
      ! -name 'systemd-private-*' \
      -exec rm -rf -- {} +

    if [[ -d "$HOME/.cache" ]]; then
      find "$HOME/.cache" -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +
    fi

    rm -rf -- \
      "$HOME/.npm/_npx" \
      "$HOME/.npm/_logs" \
      "$HOME/.julia/artifacts" \
      "$HOME/.hermes/state-snapshots"

    sudo rm -rf /var/lib/apt/lists/*
    sudo apt clean
    sudo apt-get autoclean
    sudo apt-get autoremove
    uv cache clean
    npm cache clean --force

    if command -v docker >/dev/null 2>&1; then
      docker system prune -af --volumes 2>/dev/null
    fi
    if command -v bun >/dev/null 2>&1; then
      bun pm cache rm 2>/dev/null
    fi
    if command -v yarn >/dev/null 2>&1; then
      yarn cache clean 2>/dev/null
    fi
    if command -v pip >/dev/null 2>&1; then
      pip cache purge 2>/dev/null
    fi

    df -h

# =============================================================================
# MCP Sync
# =============================================================================

# Sync centralized MCP config with ~/.envrc loaded through direnv.
# Usage: just --justfile ~/ai/home-justfile install-mcps [--dry-run] [--harness codex]
install-mcps *ARGS="":
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{ repo }}"
    direnv exec "$HOME" python3 mcp/sync_mcp_configs.py {{ ARGS }}

# =============================================================================
# LLM Usage Limits
# =============================================================================

# Check all registered providers with canonical usage-limits commands
# Usage: just usage-limits
usage-limits *ARGS="":
    @uvx --from git+https://github.com/dzackgarza/usage-limits.git usage-limits --notify --anchor {{ ARGS }}

# Collect all registered providers as structured JSON
# Usage: just usage-limits-json
usage-limits-json *ARGS="":
    @uvx --from git+https://github.com/dzackgarza/usage-limits.git usage-limits --json {{ ARGS }}

# =============================================================================
# OpenCode Rebuild
# =============================================================================

_opencode-rebuild:
    @just --justfile {{ repo }}/justfile rebuild

opencode-rebuild: _opencode-rebuild _opencode-clear-cache opencode-restart

_opencode-build-permissions:
    @just --justfile {{ repo }}/justfile permissions-apply

opencode-build-permissions: _opencode-build-permissions _opencode-clear-cache

_opencode-build-config:
    @just --justfile {{ repo }}/justfile config-build

opencode-build-config: _opencode-build-config _opencode-clear-cache

opencode-restart:
    systemctl --user restart opencode-serve
    sleep 2
    systemctl --user status opencode-serve

# =============================================================================
# Cache Cleaning
# =============================================================================

[private]
_opencode-clear-cache:
    #!/usr/bin/env bash
    set -euo pipefail
    cache_dir="${OPENCODE_PLUGIN_CACHE_DIR:-$HOME/.cache/opencode}"

    for path in \
      "$cache_dir/node_modules" \
      "$cache_dir/package.json" \
      "$cache_dir/bun.lock"
    do
      if [[ -e "$path" ]]; then
        gio trash "$path"
      fi
    done
