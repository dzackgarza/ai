# Home directory justfile - personal automation
# Usage: just --justfile ~/ai/home-justfile <recipe>

repo := env_var_or_default("REPO", env_var("HOME") / "ai")

# Show available recipes
# Usage: just
default:
    @just --list

# =============================================================================
# LLM Usage Limits
# =============================================================================

# Check the common provider set with canonical usage-limits commands
# Usage: just usage-limits
usage-limits *ARGS="":
    @uvx --from git+https://github.com/dzackgarza/usage-limits.git usage-limits table --provider claude --provider codex --provider amp --provider qwen --notify --anchor {{ ARGS }}

# Collect the same provider set as structured JSON
# Usage: just usage-limits-json
usage-limits-json *ARGS="":
    @uvx --from git+https://github.com/dzackgarza/usage-limits.git usage-limits collect --provider claude --provider codex --provider amp --provider qwen --json {{ ARGS }}

# =============================================================================
# OpenCode Rebuild
# =============================================================================

opencode-rebuild:
    @just --justfile {{ repo }}/justfile check-plugins
    @just --justfile {{ repo }}/justfile build-agents

opencode-build-permissions:
    @just --justfile {{ repo }}/justfile check-plugins
    @cd {{ repo }}/opencode && uv run --python .venv/bin/python permissions/main.py --apply

opencode-build-config:
    @just --justfile {{ repo }}/justfile check-plugins
    @cd {{ repo }}/opencode && uv run --python .venv/bin/python scripts/build_config.py

# =============================================================================
# Cache Cleaning
# =============================================================================

clear-caches:
    @bash {{ repo }}/opencode/scripts/maintenance/opencode_gc.sh
