#!/bin/sh
# Validates the candidate report at the fixed path.
# On success: copies to artifact path and exits 0.
# On failure: prints errors and exits non-zero.
# The agent fixes the same file and re-runs this script.

set -euo pipefail

HERE="$(cd "$(dirname "$0")/../.." && pwd)"
CANDIDATE="$HERE/.agents/review-runner/candidates/submitted.json"
CHECKER="$HERE/quality-control/check-report.py"
ARTIFACT="$HERE/.review-report-artifact.json"

if [ "${1:-}" = "--help" ]; then
    cat <<'HELP'
submit-candidate — validate and submit a review report

Usage:
  .agents/ci/submit-candidate            # validate and submit (default)
  .agents/ci/submit-candidate --help     # print this message

Report format (JSON written to .agents/review-runner/candidates/submitted.json):

{
  "schema_version": 1,
  "report_type": "general",
  "repo_sha": "<git-head-sha>",
  "review_scope": {
    "changed_files": [],
    "excluded_files": [],
    "required_surfaces": []
  },
  "findings": [
    {
      "tier": "tier1",
      "label": "BLOCKER",
      "category": "semantic-regression",
      "location": {
        "path": "src/foo.ts",
        "start_line": 10,
        "end_line": 25
      },
      "symptom": "Description of the problem",
      "source": "Root cause analysis",
      "consequence": "Impact if not fixed",
      "remedy": "Suggested fix",
      "evidence": [
        {"kind": "file-read", "path": "src/foo.ts", "lines": [1, 80]}
      ]
    }
  ],
  "checked_surfaces": [
    {
      "path": "src/foo.ts",
      "reason": "high-churn",
      "lines_read": [1, 120],
      "result": "finding"
    }
  ],
  "rejected_easy_wins": [],
  "score": 85,
  "report": "## Markdown Audit Report Summary\n\nFull formatted report here."
}

report_type must be "general" or "slop".
Forbidden categories: infra, infrastructure, ci, workflow, config.
Every finding must include: tier, label, category, location, symptom, source, consequence, evidence.
Score 0-100.
HELP
    exit 0
fi

if ! [ -f "$CANDIDATE" ]; then
    echo "ERROR: No report found at $CANDIDATE"
    echo "Write your report to $CANDIDATE first, then run this script."
    exit 1
fi

if python3 "$CHECKER" "$CANDIDATE" 2>&1; then
    cp "$CANDIDATE" "$ARTIFACT"
    exit 0
fi
exit 1
