# Validate a brooks-lint/slop report and write it to the canonical artifact.
# The agent MUST call this to submit a report — there is no other path.
# - If validation fails → exits non-zero → agent retries
# - If validation passes → writes .brooks-report-artifact.json (CI posts from this)
#
# Usage:
#   just post-brooks-review <result.json> <pr-number>
set shell := ['bash', '-c']

[private]
post-brooks-review result pr-number:
    set -euo pipefail

    # Validate — checker has PEP 723 metadata declared in its shebang
    scripts/check-brooks-report.py "{{result}}"

    # Write canonical artifact (CI posts from this — no re-validation)
    cp "{{result}}" .brooks-report-artifact.json
    echo "Report validated. Artifact written to .brooks-report-artifact.json"
