# Post a brooks-lint review as a PR comment.
# Validates the report first — rejects launder patterns, empty reports,
# missing finding labels, and missing file-path evidence.
#
# Usage:
#   just post-brooks-review <result.json> <pr-number>
#
# The only way to post a review comment — no bypass path.
[private]
post-brooks-review result pr-number:
    set -euo pipefail

    # Validate — checker has PEP 723 metadata, skip project context
    uv run --no-project .agents/scripts/check-brooks-report.py "{{result}}"

    # Parse and post
    report=$$(jq -r '.report' "{{result}}")
    score=$$(jq -r '.score // "N/A"' "{{result}}")
    body=$$(printf '## Brooks-Lint Review (OpenCode)\n\n%s\n\n---\n_Health Score: %s_' "$${report}" "$${score}")
    gh pr comment "{{pr-number}}" --body "$${body}"
    echo "Posted review to PR #{{pr-number}}"
