# Submit a candidate brooks-lint/slop report.
# This command is for agents to submit their analysis for validation by the CI harness.
#
# Usage:
#   just submit-brooks-candidate <result.json>
set shell := ['bash', '-c']

[private]
submit-brooks-candidate result:
    set -euo pipefail

    # Use /tmp/brooks/candidates explicitly, which is allowed by agent permissions
    TARGET_DIR="/tmp/brooks/candidates"
    mkdir -p "$TARGET_DIR"

    # Copy to a timestamped file to avoid overwriting and allow harvesting
    cp "{{result}}" "$TARGET_DIR/candidate-$(date +%s).json"
    echo "Candidate submitted to harness for validation."
