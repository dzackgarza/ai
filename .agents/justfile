# Post a brooks-lint / slop review as a PR comment.
# Validates the report first — rejects launder patterns, empty reports,
# missing finding labels, missing file-path evidence, and Mermaid errors.
#
# Usage:
#   just post-brooks-review <result.json> <pr-number>
#
# The only way to post a review comment — no bypass path.
[private]
post-brooks-review result pr-number:
    set -euo pipefail

    # Validate
    uv run .agents/scripts/check-brooks-report.py "{{result}}"

    # Parse and post via stdin — avoids bash escaping issues with \n
    report=$$(jq -r '.report' "{{result}}")
    score=$$(jq -r '.score // "N/A"' "{{result}}")

    {
        echo "## Review (OpenCode)"
        echo ""
        echo "$${report}"
        echo ""
        echo "---"
        echo "_Health Score: $${score}_"
    } | gh pr comment "{{pr-number}}" --body -
    echo "Posted review to PR #{{pr-number}}"
