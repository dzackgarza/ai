source_up
# Environment variables for AI Configuration repository
export GEMINI_SYSTEM_MD="/home/dzack/ai/opencode/agents/interactive.md"
export QWEN_SYSTEM_MD="/home/dzack/ai/opencode/agents/interactive.md"

# Helper function: runs codex with custom instructions from a file (from GitHub discussion)
codex-with-instructions() {
  local instructions_file="$1"
  shift

  if [ ! -f "$instructions_file" ]; then
    echo "Error: instructions file not found: $instructions_file" >&2
    return 1
  fi

  local instructions
  instructions="$(<"$instructions_file")"

  codex --config developer_instructions="$instructions" "$@"
}

# Override the codex command to use our system prompt by default (based on approach from openai/codex discussion #7296)
codex() {
  codex-with-instructions "/home/dzack/ai/opencode/agents/interactive.md" "$@"
}
