root := justfile_directory() / ".."

default:
	@echo "run: just -f AGENTSmd/.agents/justfile assemble"

# Rebuild AGENTS.md.generated from the fragment tree (frontmatter + pandoc include-files).
# The repo-root AGENTS.md is a symlink to this generated file.
assemble:
	@if [ -e "{{justfile_directory()}}/AGENTS.md.generated" ]; then chmod u+w "{{justfile_directory()}}/AGENTS.md.generated"; fi
	@{{justfile_directory()}}/assemble.py "{{root}}" "{{justfile_directory()}}/AGENTS.md.generated"
	@chmod a-w "{{justfile_directory()}}/AGENTS.md.generated"

# Flowmark the editable source fragments (semantic line breaks for human editing).
format:
	@just ~/.pandoc/justfile format-markdown $(find "{{root}}" -name '*.md' -not -path '*/.agents/*' -not -name README.md)
