default:
	@echo "run: just -f AGENTSmd/justfile assemble"

# Rebuild AGENTS.md from the fragment tree (frontmatter + pandoc include-files).
assemble:
	@{{justfile_directory()}}/assemble.py "{{justfile_directory()}}" "{{justfile_directory()}}/AGENTS.md"

# Flowmark the editable source fragments (semantic line breaks for human editing).
format:
	@just ~/.pandoc/justfile format-markdown $(find "{{justfile_directory()}}" -name '*.md' -not -name AGENTS.md -not -path '*/filters/*')
